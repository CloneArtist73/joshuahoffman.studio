---
import { siteConfig } from '../data/site';
import { contactClick, inquirySubmit } from '../utils/analytics';

const isNetlify = siteConfig.contactForm.provider === 'netlify';
const hasConfiguredForm = siteConfig.contactForm.provider !== 'none';
const directEmailHref = `mailto:${siteConfig.email}?subject=Photography%20inquiry`;
---

{hasConfiguredForm ? (
<div class="surface p-6 sm:p-8">
  <div
    class="mb-5 hidden rounded-panel border border-ember/50 bg-ember/10 p-4 text-sm text-sand"
    data-contact-error
    role="alert"
  >
  </div>
  <form
    action={siteConfig.contactForm.action}
    method="POST"
    name="contact"
    data-contact-form
    netlify-honeypot={isNetlify ? 'bot-field' : undefined}
    data-netlify={isNetlify ? 'true' : undefined}
    {...inquirySubmit({ form: 'contact_page' })}
  >
    <input name="form-name" type="hidden" value="contact" />
    {isNetlify && <input name="bot-field" type="hidden" />}
    <div aria-hidden="true" class="absolute -left-[10000px] top-auto h-px w-px overflow-hidden">
      <label for="website">Website</label>
      <input autocomplete="off" id="website" name="website" tabindex="-1" type="text" />
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <label class="form-field" for="name">
        <span class="form-field-label">Name</span>
        <input
          aria-describedby="name-help name-error"
          autocomplete="name"
          id="name"
          name="name"
          placeholder="Your name"
          required
          type="text"
        />
        <span class="form-help" id="name-help">Your preferred name is enough.</span>
        <span class="form-error" id="name-error">Enter your name.</span>
      </label>

      <label class="form-field" for="email">
        <span class="form-field-label">Email</span>
        <input
          aria-describedby="email-help email-error"
          autocomplete="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          required
          type="email"
        />
        <span class="form-help" id="email-help">Use the address Joshua should reply to.</span>
        <span class="form-error" id="email-error">Enter a valid email address.</span>
      </label>
    </div>

    <label class="form-field mt-5" for="inquiry-type">
      <span class="form-field-label">Inquiry type</span>
      <select aria-describedby="inquiry-type-help inquiry-type-error" id="inquiry-type" name="inquiryType" required>
        <option value="">Select one</option>
        <option value="Portrait session">Portrait session</option>
        <option value="Legacy / memorial work">Legacy / memorial work</option>
        <option value="Musician / artist portraits">Musician / artist portraits</option>
        <option value="Print or product question">Print or product question</option>
        <option value="Licensing">Licensing</option>
        <option value="Other">Other</option>
      </select>
      <span class="form-help" id="inquiry-type-help">Choose the closest fit for this note.</span>
      <span class="form-error" id="inquiry-type-error">Choose an inquiry type.</span>
    </label>

    <label class="form-field mt-5" for="message">
      <span class="form-field-label">Message</span>
      <textarea
        aria-describedby="message-help message-error"
        id="message"
        name="message"
        placeholder="Tell Joshua what you need, what you are drawn to, and any timing that matters."
        required
      ></textarea>
      <span class="form-help" id="message-help">Include timing, location, and the kind of work you have in mind.</span>
      <span class="form-error" id="message-error">Add a brief message.</span>
    </label>

    <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="min-w-0 flex-1 text-sm text-steel">
        Prefer direct email? Reach out at
        <a
          class="panel-link text-paper underline decoration-white/30 underline-offset-4 hover:decoration-platinum"
          href={`mailto:${siteConfig.email}`}
          data-link-type="email_contact"
          data-link-label={`Email contact: ${siteConfig.email}`}
          data-link-location="contact_form"
          {...contactClick({ location: 'contact_page_email' })}
        >
          {siteConfig.email}
        </a>
        and Joshua will reply directly.
      </p>
      <button
        class="btn btn-primary w-full shrink-0 whitespace-nowrap sm:w-auto"
        data-default-label="Start an Inquiry"
        type="submit"
      >
        <span>Start an Inquiry</span>
      </button>
    </div>
  </form>
</div>
) : (
<div class="surface space-y-5 p-6 sm:p-8">
  <div class="space-y-3">
    <span class="eyebrow">Direct inquiry</span>
    <h2 class="text-3xl">Email Joshua directly.</h2>
    <p class="text-sm text-steel sm:text-base">
      Include the kind of work you need, your timing, location, and any image or print that brought you here.
    </p>
  </div>
  <a
    class="btn btn-primary"
    href={directEmailHref}
    data-link-type="email_contact"
    data-link-label={`Email contact: ${siteConfig.email}`}
    data-link-location="contact_direct_inquiry"
    {...contactClick({ location: 'contact_direct_inquiry' })}
  >
    Email Joshua
  </a>
  <p class="text-sm text-steel">
    Direct email keeps the inquiry reliable and leaves room for timing, privacy, and project details.
  </p>
</div>
)}

<script is:inline>
  const params = new URLSearchParams(window.location.search);
  const inquiryType = params.get('type');
  const imageSlug = params.get('image');
  const errorType = params.get('error');
  const messageField = document.getElementById('message');
  const inquirySelect = document.getElementById('inquiry-type');
  const errorPanel = document.querySelector('[data-contact-error]');

  const errorMessages = {
    missing: 'Please fill in each required field and send the note again.',
    email: 'Please enter a valid email address so Joshua can reply directly.',
    send: 'The form could not send the message. Email Joshua directly, or try again in a few minutes.',
  };

  if (errorType && errorPanel instanceof HTMLElement) {
    errorPanel.textContent = errorMessages[errorType] || errorMessages.send;
    errorPanel.classList.remove('hidden');
  }

  if (inquiryType && inquirySelect instanceof HTMLSelectElement) {
    inquirySelect.value = inquiryType;
  }

  if (imageSlug && messageField instanceof HTMLTextAreaElement && !messageField.value) {
    messageField.value = `I am reaching out about ${imageSlug.replaceAll('-', ' ')}.`;
  }

  const contactForm = document.querySelector('[data-contact-form]');
  const submitButton = contactForm?.querySelector('button[type="submit"]');

  if (contactForm instanceof HTMLFormElement && submitButton instanceof HTMLButtonElement) {
    const defaultSubmitLabel = submitButton.dataset.defaultLabel ?? submitButton.textContent ?? 'Start an Inquiry';

    contactForm.addEventListener('submit', () => {
      submitButton.disabled = true;
      submitButton.setAttribute('aria-busy', 'true');
      submitButton.textContent = 'Sending...';
    });

    window.addEventListener('pageshow', () => {
      submitButton.disabled = false;
      submitButton.removeAttribute('aria-busy');
      submitButton.textContent = defaultSubmitLabel;
    });
  }
</script>
