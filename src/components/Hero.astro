---
import type { CtaItem } from '../data/types';
import CTAButton from './CTAButton.astro';
import { trackingAttributes } from '../utils/analytics';

interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  imageSrc?: string;
  imageAlt?: string;
  primaryCta: CtaItem;
  secondaryCta?: CtaItem;
}

const {
  eyebrow = 'Joshua Hoffman Studio',
  title,
  text,
  imageSrc,
  imageAlt,
  primaryCta,
  secondaryCta,
} = Astro.props;

const hasImage = Boolean(imageSrc);

function ctaTracking(cta: CtaItem, fallbackLocation: string) {
  if (!cta.eventName) {
    return {};
  }

  return trackingAttributes(cta.eventName as never, {
    location: fallbackLocation,
    ...(cta.eventProps ?? {}),
  });
}
---

<section class="section-block pt-10 sm:pt-14">
  <div
    class:list={[
      'grid gap-10',
      hasImage
        ? 'shell items-center lg:grid-cols-[minmax(0,0.88fr)_minmax(0,1.12fr)]'
        : 'mx-auto w-full max-w-5xl px-5 sm:px-6 lg:px-8',
    ]}
  >
    <div class="space-y-6">
      <span class="eyebrow">{eyebrow}</span>
      <h1 class="headline max-w-4xl">{title}</h1>
      <p class="max-w-copy text-base leading-relaxed text-steel sm:text-lg">{text}</p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <CTAButton
          href={primaryCta.href}
          label={primaryCta.label}
          tracking={ctaTracking(primaryCta, 'hero_primary')}
        />
        {
          secondaryCta && (
            <CTAButton
              href={secondaryCta.href}
              label={secondaryCta.label}
              tracking={ctaTracking(secondaryCta, 'hero_secondary')}
              variant="secondary"
            />
          )
        }
      </div>
    </div>

    {
      hasImage && (
        <div class="mt-10 sm:hidden">
          <div class="image-frame w-[calc(100%+1.25rem)] -mr-5 rounded-r-none border-r-0">
            <img
              alt={imageAlt ?? ''}
              class="aspect-[16/9] w-full object-cover"
              decoding="async"
              fetchpriority="high"
              height="1100"
              loading="eager"
              src={imageSrc}
              width="1320"
            />
          </div>
        </div>
      )
    }

    {
      hasImage && (
        <div class="image-frame hidden sm:block">
          <img
            alt={imageAlt ?? ''}
            class="aspect-[6/5] w-full object-cover"
            decoding="async"
            fetchpriority="high"
            height="1100"
            loading="eager"
            sizes="(min-width: 1024px) 44vw, calc(100vw - 2.5rem)"
            src={imageSrc}
            width="1320"
          />
        </div>
      )
    }
  </div>
</section>
