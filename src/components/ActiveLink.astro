---
interface Props {
  href: string;
  class?: string;
  activeClass?: string;
  inactiveClass?: string;
  [key: string]: any;
}

const {
  href,
  class: className,
  activeClass = 'text-paper underline decoration-sage/70 underline-offset-8',
  inactiveClass = 'text-steel hover:text-paper',
  ...rest
} = Astro.props;

const normalizePath = (path: string) => (path === '/' ? path : path.replace(/\/$/, ''));
const currentPath = normalizePath(Astro.url.pathname);
const isActive = normalizePath(href) === currentPath;
---

<a
  href={href}
  aria-current={isActive ? 'page' : undefined}
  class:list={[className, isActive ? activeClass : inactiveClass]}
  {...rest}
>
  <slot />
</a>
