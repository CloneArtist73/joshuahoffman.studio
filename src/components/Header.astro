---
import CTAButton from './CTAButton.astro';
import { primaryNavLinks, secondaryNavLinks, siteConfig } from '../data/site';
import { bookSessionClick } from '../utils/analytics';

const normalizePath = (path: string) => (path === '/' ? path : path.replace(/\/$/, ''));
const currentPath = normalizePath(Astro.url.pathname);
const isCurrentLink = (href: string) => normalizePath(href) === currentPath;
const hasCurrentSecondaryLink = secondaryNavLinks.some((item) => isCurrentLink(item.href));
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-obsidian/80 backdrop-blur">
  <div class="shell flex items-center justify-between gap-3 py-4 sm:gap-4">
    <a class="panel-link min-w-0 max-w-[16rem] lg:max-w-[15rem] xl:max-w-none" href="/">
      <span class="block truncate font-display text-2xl text-paper">{siteConfig.brandName}</span>
      <span class="copy-muted block truncate text-xs uppercase tracking-hush">
        {siteConfig.ownerName} · {siteConfig.serviceArea}
      </span>
    </a>

    <nav aria-label="Primary navigation" class="hidden items-center gap-3 lg:flex xl:gap-4">
      {
        primaryNavLinks.map((item) => (
          <a
            aria-current={isCurrentLink(item.href) ? 'page' : undefined}
            class:list={[
              'panel-link whitespace-nowrap text-sm transition',
              isCurrentLink(item.href)
                ? 'text-paper underline decoration-sage/70 underline-offset-8'
                : 'text-steel hover:text-paper',
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
      <div class="hidden items-center gap-3 xl:flex xl:gap-4">
        {
          secondaryNavLinks.map((item) => (
            <a
              aria-current={isCurrentLink(item.href) ? 'page' : undefined}
              class:list={[
                'panel-link whitespace-nowrap text-sm transition',
                isCurrentLink(item.href)
                  ? 'text-paper underline decoration-sage/70 underline-offset-8'
                  : 'text-steel hover:text-paper',
              ]}
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <details class="relative shrink-0 xl:hidden">
        <summary
          class:list={[
            'panel-link inline-flex min-h-11 cursor-pointer items-center rounded-full border border-white/10 px-4 py-2 text-sm font-semibold',
            hasCurrentSecondaryLink ? 'bg-white/10 text-paper' : 'bg-white/5 text-steel hover:text-paper',
          ]}
        >
          More
        </summary>
        <div class="surface absolute right-0 top-[calc(100%+0.75rem)] min-w-48 p-3 shadow-soft">
          <nav class="flex flex-col gap-1">
            {
              secondaryNavLinks.map((item) => (
                <a
                  aria-current={isCurrentLink(item.href) ? 'page' : undefined}
                  class:list={[
                    'panel-link rounded-2xl px-3 py-2 text-sm',
                    isCurrentLink(item.href)
                      ? 'bg-white/10 text-paper'
                      : 'text-steel hover:bg-white/5 hover:text-paper',
                  ]}
                  href={item.href}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </details>

      <CTAButton
        class="shrink-0 whitespace-nowrap"
        href="/contact/?type=Portrait%20session"
        label="Start an Inquiry"
        trackingMeta={{
          'data-link-type': 'booking_inquiry',
          'data-link-intent': 'portrait_booking',
          'data-link-location': 'header_desktop_cta',
        }}
        tracking={bookSessionClick({ service: 'portrait', location: 'header' })}
      />
    </nav>

    <details class="relative lg:hidden">
      <summary class="panel-link inline-flex min-h-11 cursor-pointer items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-paper">
        Menu
      </summary>
      <div class="surface absolute right-0 top-[calc(100%+0.75rem)] min-w-64 p-4 shadow-soft">
        <nav aria-label="Mobile navigation" class="flex flex-col gap-2">
          {
            [...primaryNavLinks, ...secondaryNavLinks].map((item) => (
              <a
                aria-current={isCurrentLink(item.href) ? 'page' : undefined}
                class:list={[
                  'panel-link rounded-2xl px-3 py-2 text-sm',
                  isCurrentLink(item.href)
                    ? 'bg-white/10 text-paper'
                    : 'text-steel hover:bg-white/5 hover:text-paper',
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
          <div class="pt-2">
            <CTAButton
              href="/contact/?type=Portrait%20session"
              label="Start an Inquiry"
              class="w-full"
              trackingMeta={{
                'data-link-type': 'booking_inquiry',
                'data-link-intent': 'portrait_booking',
                'data-link-location': 'header_mobile_cta',
              }}
              tracking={bookSessionClick({ service: 'portrait', location: 'mobile_menu' })}
            />
          </div>
        </nav>
      </div>
    </details>
  </div>
</header>
