---
import CTAButton from './CTAButton.astro';
import ActiveLink from './ActiveLink.astro';
import { primaryNavLinks, secondaryNavLinks, siteConfig } from '../data/site';
import { contactClick } from '../utils/analytics';

const normalizePath = (path: string) => (path === '/' ? path : path.replace(/\/$/, ''));
const currentPath = normalizePath(Astro.url.pathname);
const isCurrentLink = (href: string) => normalizePath(href) === currentPath;
const hasCurrentSecondaryLink = secondaryNavLinks.some((item) => isCurrentLink(item.href));
---

<header class="sticky top-0 z-40 border-b border-platinum/10 bg-obsidian/90 backdrop-blur">
  <div class="shell relative flex items-center justify-between gap-2 py-4 sm:gap-4">
    <a class="panel-link min-w-0 max-w-[12rem] sm:max-w-[16rem] lg:max-w-[15rem] xl:max-w-none" href="/">
      <span class="block truncate font-display text-2xl text-paper">{siteConfig.brandName}</span>
      <span class="copy-muted block truncate text-xs uppercase tracking-hush">
        {siteConfig.ownerName} · {siteConfig.serviceArea}
      </span>
    </a>

    <nav aria-label="Primary navigation" class="hidden items-center gap-3 lg:flex xl:gap-4">
      {
        primaryNavLinks.map((item) => (
          <ActiveLink
            class="panel-link whitespace-nowrap rounded-full px-3 py-2 text-sm transition"
            href={item.href}
          >
            {item.label}
          </ActiveLink>
        ))
      }
      <div class="hidden items-center gap-3 xl:flex xl:gap-4">
        {
          secondaryNavLinks.map((item) => (
            <ActiveLink
              class="panel-link whitespace-nowrap rounded-full px-3 py-2 text-sm transition"
              href={item.href}
            >
              {item.label}
            </ActiveLink>
          ))
        }
      </div>

      <details class="relative shrink-0 xl:hidden" data-site-menu>
        <summary
          aria-label="Open secondary navigation"
          class:list={[
            'panel-link inline-flex min-h-11 cursor-pointer items-center rounded-full border border-white/10 px-4 py-2 text-sm font-semibold',
            hasCurrentSecondaryLink ? 'bg-white/10 text-paper' : 'bg-white/5 text-steel hover:text-paper',
          ]}
        >
          More
        </summary>
        <div class="surface absolute right-0 top-[calc(100%+0.75rem)] min-w-48 p-3 shadow-soft">
          <nav class="flex flex-col gap-1">
            {
              secondaryNavLinks.map((item) => (
                <ActiveLink
                  activeClass="bg-white/10 text-paper"
                  class="panel-link rounded-panel px-3 py-2 text-sm"
                  data-menu-link
                  href={item.href}
                  inactiveClass="text-steel hover:bg-white/5 hover:text-paper"
                >
                  {item.label}
                </ActiveLink>
              ))
            }
          </nav>
        </div>
      </details>

      <CTAButton
        class="shrink-0 whitespace-nowrap"
        href="/contact/"
        label="Start an Inquiry"
        trackingMeta={{
          'data-link-type': 'booking_inquiry',
          'data-link-intent': 'general_inquiry',
          'data-link-location': 'header_desktop_cta',
        }}
        tracking={contactClick({ service: 'custom', location: 'header' })}
      />
    </nav>

    <details class="absolute right-4 top-1/2 -translate-y-1/2 lg:hidden" data-site-menu>
      <summary aria-label="Open site navigation" class="panel-link inline-flex min-h-11 cursor-pointer items-center rounded-full border border-white/10 bg-white/5 px-3 py-2 text-sm font-semibold text-paper sm:px-4">
        Menu
      </summary>
      <div class="surface absolute right-0 top-[calc(100%+0.75rem)] min-w-64 p-4 shadow-soft">
        <nav aria-label="Mobile navigation" class="flex flex-col gap-2">
          {
            [...primaryNavLinks, ...secondaryNavLinks].map((item) => (
              <ActiveLink
                activeClass="bg-white/10 text-paper"
                class="panel-link rounded-panel px-3 py-2 text-sm"
                data-menu-link
                href={item.href}
                inactiveClass="text-steel hover:bg-white/5 hover:text-paper"
              >
                {item.label}
              </ActiveLink>
            ))
          }
          <div class="pt-2">
            <CTAButton
              href="/contact/"
              label="Start an Inquiry"
              class="w-full"
              trackingMeta={{
                'data-menu-link': 'true',
                'data-link-type': 'booking_inquiry',
                'data-link-intent': 'general_inquiry',
                'data-link-location': 'header_mobile_cta',
              }}
              tracking={contactClick({ service: 'custom', location: 'mobile_menu' })}
            />
          </div>
        </nav>
      </div>
    </details>
  </div>
</header>

<script is:inline>
  const siteMenus = Array.from(document.querySelectorAll('header details[data-site-menu]'));

  document.addEventListener('click', (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    siteMenus.forEach((menu) => {
      if (target.closest('[data-menu-link]')) {
        menu.removeAttribute('open');
        return;
      }

      if (!menu.contains(target)) {
        menu.removeAttribute('open');
      }
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') {
      return;
    }

    siteMenus.forEach((menu) => menu.removeAttribute('open'));
  });
</script>
