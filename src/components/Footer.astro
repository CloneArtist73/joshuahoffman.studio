---
import CTAButton from './CTAButton.astro';
import ActiveLink from './ActiveLink.astro';
import { primaryNavLinks, secondaryNavLinks, siteConfig, socialLinks } from '../data/site';
import { contactClick } from '../utils/analytics';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-white/10">
  <div class="shell section-block grid gap-10 lg:grid-cols-[1.3fr_0.8fr_0.8fr]">
    <div class="space-y-4">
      <span class="eyebrow">Prints first, direct when needed</span>
      <h2 class="max-w-xl text-3xl sm:text-4xl">{siteConfig.brandName}</h2>
      <p class="max-w-copy text-steel">
        Physical prints, real on-location astrophotography, portraits, artist images, restoration-style print work, and licensing inquiries.
      </p>
      <div class="flex flex-wrap gap-3">
        <CTAButton
          href="/contact/"
          label="Contact Joshua"
          variant="secondary"
          tracking={contactClick({ location: 'footer_primary_cta' })}
        />
        <CTAButton href="/prints/" label="View Prints" variant="ghost" />
      </div>
    </div>

    <div class="space-y-3">
      <h3 class="text-xs font-sans font-semibold tracking-wide text-steel uppercase">Browse</h3>
      <nav class="flex flex-col gap-2">
        {
          [...primaryNavLinks, ...secondaryNavLinks].map((item) => (
            <ActiveLink
              activeClass="text-paper underline decoration-sage/70 underline-offset-4"
              class="panel-link text-sm transition"
              href={item.href}
            >
              {item.label}
            </ActiveLink>
          ))
        }
      </nav>
    </div>

    <div class="space-y-3">
      <h3 class="text-xs font-sans font-semibold tracking-wide text-steel uppercase">Contact</h3>
      <a
        class="panel-link block text-sm text-steel hover:text-paper"
        href={`mailto:${siteConfig.email}`}
        data-link-type="email_contact"
        data-link-label={`Email contact: ${siteConfig.email}`}
        data-link-location="footer_email"
        {...contactClick({ location: 'footer_email' })}
      >
        {siteConfig.email}
      </a>
      <p class="text-sm text-steel">{siteConfig.serviceArea}</p>
      <div class="flex flex-col gap-2">
        {
          socialLinks.map((item) => (
            <a
              aria-label={`Visit Joshua Hoffman's ${item.label}`}
              class="panel-link block text-sm text-steel hover:text-paper"
              href={item.href}
              rel="noreferrer noopener"
              target="_blank"
              {...contactClick({ location: 'footer_social', network: item.label.toLowerCase() })}
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="border-t border-white/10 py-6">
    <div class="shell flex flex-col gap-2 text-xs uppercase tracking-hush text-steel sm:flex-row sm:items-center sm:justify-between">
      <span>{siteConfig.ownerName}</span>
      <span>© {currentYear} {siteConfig.brandName}</span>
    </div>
  </div>
</footer>
