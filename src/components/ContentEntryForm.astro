---
import { entryAiPrompt } from '../data/entryAiPrompt';

interface SeedData {
  images?: unknown[];
  products?: unknown[];
  externalLinks?: Record<string, unknown>;
}

interface Props {
  seedData?: string;
}

const { seedData = '{}' } = Astro.props as Props;
const entryAiPromptJson = JSON.stringify(entryAiPrompt).replace(/</g, '\\u003c');
---

<section class="section-block pt-10">
  <div class="shell grid gap-8 xl:grid-cols-[1.05fr_0.95fr]">
    <div class="space-y-8">
      <div class="space-y-4">
        <span class="eyebrow">Local helper</span>
        <h1 class="headline max-w-4xl">Entry form for new image, product, and outbound URL data.</h1>
        <p class="max-w-copy text-base text-steel sm:text-lg">
          This page stays local-only. Submit can copy a selected image into <code>public/images</code>
          and add the local data entries used by the gallery before you push the site.
        </p>
      </div>

      <div class="surface p-6 sm:p-8">
        <div
          aria-label="Entry workflow"
          class="mb-8 flex flex-wrap gap-3 rounded-2xl border border-white/10 bg-white/5 p-2"
          role="tablist"
        >
          <button
            class="panel-link inline-flex items-center justify-center rounded-full border border-white/10 bg-obsidian/70 px-5 py-3 text-sm font-semibold text-paper"
            data-entry-tab="file-import"
            role="tab"
            aria-controls="file-import-panel"
            type="button"
          >
            File import
          </button>
          <button
            class="panel-link inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-paper"
            data-entry-tab="edit-gallery"
            role="tab"
            aria-controls="edit-gallery-panel"
            type="button"
          >
            Edit gallery
          </button>
        </div>

        <form class="space-y-8" id="content-entry-form" novalidate>
          <div
            aria-live="polite"
            class="hidden rounded-2xl border px-4 py-3 text-sm"
            id="entry-status"
            role="status"
          ></div>

          <section class="space-y-5" aria-labelledby="file-import" data-entry-panel="file-import" id="file-import-panel">
            <div class="space-y-2">
              <h2 class="text-2xl" id="file-import">File import</h2>
              <p class="copy-muted">
                Choose a local image file and your repo root. Submit copies the file into
                <code>public/images</code> and writes the gallery data locally.
              </p>
            </div>

            <div class="space-y-5" id="local-file-controls">
              <div
                class="rounded-2xl border border-amber-400/30 bg-amber-400/10 px-4 py-3 text-sm text-sand"
                id="file-import-support"
              ></div>

              <div class="grid gap-5 sm:grid-cols-2">
                <label class="space-y-2 text-sm text-paper" for="image-file">
                  <span id="image-file-label">Choose image file</span>
                  <input
                    accept="image/*,.jpg,.jpeg,.png,.webp,.avif,.gif,.tif,.tiff"
                    class="cursor-pointer file:mr-4 file:rounded-full file:border-0 file:bg-white/10 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-paper hover:file:bg-white/15"
                    id="image-file"
                    name="imageFile"
                    type="file"
                  />
                  <span class="copy-muted block" id="image-file-meta">
                    No image file selected yet.
                  </span>
                </label>

                <div class="space-y-2 text-sm text-paper">
                  <span class="block">Choose project root</span>
                  <button
                    class="panel-link inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-paper hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-50"
                    data-choose-images-folder
                    type="button"
                  >
                    Choose repo folder
                  </button>
                  <span class="copy-muted block" id="images-folder-meta">
                    No project folder selected yet.
                  </span>
                </div>
              </div>

              <div class="grid gap-5 sm:grid-cols-[0.75fr_1.25fr]">
                <label class="space-y-2 text-sm text-paper" for="image-subfolder">
                  <span>Optional subfolder</span>
                  <input
                    id="image-subfolder"
                    name="imageSubfolder"
                    placeholder="portraits/live"
                    type="text"
                  />
                  <span class="copy-muted block">
                    Use nested paths like <code>portraits</code> or <code>musicians/live</code>. Each part
                    will be sanitized to kebab-case.
                  </span>
                </label>

                <div class="space-y-2 text-sm text-paper">
                  <span class="block">Final project path</span>
                  <div class="rounded-2xl border border-white/10 bg-obsidian/60 px-4 py-3">
                    <code class="text-xs text-paper" id="import-path-preview">
                      Choose a file and enter a title or slug to preview the imported path.
                    </code>
                  </div>
                  <span class="copy-muted block">
                    Imported files are renamed to the image slug and keep the original extension.
                  </span>
                </div>
              </div>

              <div class="hidden overflow-hidden rounded-2xl border border-white/10 bg-white/5" id="image-preview-wrap">
                <img
                  alt="Preview of the selected local image file."
                  class="max-h-96 w-full object-contain"
                  id="image-preview"
                  src=""
                />
              </div>
            </div>
          </section>

          <section class="hidden space-y-5" aria-labelledby="edit-gallery" data-entry-panel="edit-gallery" id="edit-gallery-panel">
            <div class="space-y-2">
              <h2 class="text-2xl" id="edit-gallery">Edit gallery</h2>
              <p class="copy-muted">
                Select an existing image and edit its metadata, product links, and outbound links.
              </p>
            </div>

            <label class="space-y-2 text-sm text-paper" for="edit-image-select">
              <span>Existing image</span>
              <select id="edit-image-select" name="editImageSelect">
                <option value="">Choose an image to edit</option>
              </select>
              <span class="copy-muted block" id="edit-image-meta">
                Select a current gallery image to pre-fill image and product fields.
              </span>
            </label>
          </section>

          <section class="space-y-5 border-t border-white/10 pt-8" id="ai-review-panel">
            <div class="space-y-2">
              <span class="eyebrow">PromptForge local export</span>
              <h2 class="text-2xl">AI image review</h2>
              <p class="copy-muted">
                Run a local vision model against the selected image, then review and apply suggested field
                values yourself.
              </p>
            </div>

            <div
              aria-live="polite"
              class="rounded-2xl border border-amber-400/30 bg-amber-400/10 px-4 py-3 text-sm text-paper"
              id="ai-review-local-warning"
            >
              AI review is intended for local use only. Controls appear on localhost, file URLs, or with
              <code>?localAi=1</code>.
            </div>

            <div class="space-y-5" id="ai-review-controls">
              <div class="grid gap-5 lg:grid-cols-[0.8fr_1fr_0.8fr]">
                <label class="space-y-2 text-sm text-paper" for="ai-provider">
                  <span>Local provider</span>
                  <select id="ai-provider" name="aiProvider">
                    <option value="ollama" selected={entryAiPrompt.providerDefault === 'ollama'}>Ollama image review</option>
                    <option value="promptforge" selected={entryAiPrompt.providerDefault === 'promptforge'}>PromptForge launcher</option>
                  </select>
                  <span class="copy-muted block" id="ai-provider-help">
                    Ollama is used for image scans when a vision model is installed and running.
                  </span>
                </label>

                <label class="space-y-2 text-sm text-paper" for="ai-endpoint">
                  <span>Endpoint</span>
                  <input id="ai-endpoint" name="aiEndpoint" type="url" value={entryAiPrompt.endpointDefault} />
                </label>

                <label class="space-y-2 text-sm text-paper" for="ai-model">
                  <span>Model name</span>
                  <input id="ai-model" list="ai-model-options" name="aiModel" type="text" value={entryAiPrompt.modelDefault} />
                  <select id="ai-model-preset" name="aiModelPreset">
                    <option value="">Custom model name (typed)</option>
                  </select>
                  <datalist id="ai-model-options"></datalist>
                  <span class="copy-muted block" id="ai-model-preset-hint">
                    Choose a preset to fill the model name quickly, or type a custom value.
                  </span>
                  <span class="copy-muted block" id="ai-model-meta">
                    Refresh models after the local provider is running.
                  </span>
                </label>
              </div>

              <div class="grid gap-5 lg:grid-cols-[0.85fr_1.15fr]">
                <div class="space-y-3">
                  <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-steel">
                    <p class="text-paper">
                      Prompt: {entryAiPrompt.source} · {entryAiPrompt.channel} · {entryAiPrompt.version}
                    </p>
                    <p class="mt-2">
                      The model can suggest descriptive content, category, orientation, service routing, and
                      print notes. Product fields stay opt-in. It should not guess year, location, storefront
                      URLs, or identities.
                    </p>
                  </div>

                  <div class="grid gap-3 sm:grid-cols-2">
                    <button
                      class="panel-link inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-paper hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-50"
                      data-start-ai
                      type="button"
                    >
                      Start Provider
                    </button>

                    <button
                      class="panel-link inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-paper hover:bg-white/10"
                      data-refresh-ai-models
                      type="button"
                    >
                      Refresh Models
                    </button>
                  </div>

                  <button
                    class="panel-link inline-flex w-full items-center justify-center rounded-full border border-sage/70 bg-sage px-5 py-3 text-sm font-semibold text-obsidian hover:bg-[#b5c7b7] disabled:cursor-not-allowed disabled:opacity-50"
                    data-run-ai-review
                    type="button"
                  >
                    Review Selected Image
                  </button>

                  <div
                    aria-live="polite"
                    class="hidden rounded-2xl border px-4 py-3 text-sm"
                    id="ai-review-status"
                    role="status"
                  ></div>
                </div>

                <details class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <summary class="cursor-pointer text-sm font-semibold text-paper">
                    Paste review JSON fallback
                  </summary>
                  <div class="mt-4 space-y-3">
                    <textarea
                      class="min-h-48"
                      id="ai-review-json"
                      placeholder='{"title":"...","category":"portrait","tags":["portrait"],"alt":"..."}'
                    ></textarea>
                    <button
                      class="panel-link inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-paper hover:bg-white/10"
                      data-parse-ai-json
                      type="button"
                    >
                      Load Pasted Suggestions
                    </button>
                  </div>
                </details>
              </div>

              <div class="hidden space-y-4 rounded-2xl border border-white/10 bg-obsidian/60 p-4" id="ai-suggestions-wrap">
                <div class="flex flex-wrap items-center justify-between gap-3">
                  <div>
                    <h3 class="text-xl">Review suggestions</h3>
                    <p class="copy-muted">
                      Checked values will be copied into the Image section. Product fields stay unchecked until
                      you opt in.
                    </p>
                  </div>
                  <button
                    class="panel-link inline-flex items-center justify-center rounded-full border border-ember/70 bg-ember px-5 py-3 text-sm font-semibold text-obsidian hover:bg-[#d48b63]"
                    data-apply-ai-suggestions
                    type="button"
                  >
                    Apply Checked Fields
                  </button>
                </div>

                <div class="grid gap-3" id="ai-suggestions-list"></div>
                <div class="hidden rounded-2xl border border-amber-400/30 bg-amber-400/10 px-4 py-3 text-sm text-paper" id="ai-cautions"></div>
              </div>
            </div>
          </section>

          <section class="space-y-5 border-t border-white/10 pt-8" id="image-entry-section">
            <div class="space-y-2">
              <h2 class="text-2xl">Image</h2>
              <p class="copy-muted">
                These fields generate the object for <code>src/data/images.ts</code>.
              </p>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="space-y-2 text-sm text-paper" for="image-title">
                <span>Title</span>
                <input id="image-title" name="imageTitle" placeholder="After the Show" type="text" />
              </label>

              <label class="space-y-2 text-sm text-paper" for="image-slug">
                <span>Slug</span>
                <input id="image-slug" name="imageSlug" placeholder="after-the-show" type="text" />
                <span class="copy-muted block">
                  Leave this blank and it will derive from the title.
                </span>
              </label>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="space-y-2 text-sm text-paper" for="image-category">
                <span>Category</span>
                <select id="image-category" name="imageCategory">
                  <option value="portrait">Portrait</option>
                  <option value="legacy">Legacy</option>
                  <option value="musician">Musician</option>
                  <option value="print">Print</option>
                  <option value="personal">Personal</option>
                </select>
                <span class="copy-muted block">
                  Choose the category used for gallery grouping and service routing.
                </span>
              </label>

              <label class="space-y-2 text-sm text-paper" for="image-src">
                <span>Public image path</span>
                <input
                  id="image-src"
                  name="imageSrc"
                  placeholder="/images/portraits/after-the-show.jpg"
                  type="text"
                />
                <span class="copy-muted block">
                  Submit fills this automatically after import. In fallback mode, enter it manually.
                </span>
              </label>
            </div>

            <label class="space-y-2 text-sm text-paper" for="image-tags">
              <span>Tags</span>
              <input
                id="image-tags"
                name="imageTags"
                placeholder="musicians, performance, portrait"
                type="text"
              />
              <span class="copy-muted block">
                Use comma-separated tags for related work and future filtering.
              </span>
            </label>

            <label class="space-y-2 text-sm text-paper" for="image-alt">
              <span>Alt text</span>
              <textarea
                id="image-alt"
                name="imageAlt"
                placeholder="Low-lit portrait of a musician standing after a performance."
              ></textarea>
              <span class="copy-muted block">
                Write the image description a screen reader should announce.
              </span>
            </label>

            <label class="space-y-2 text-sm text-paper" for="image-hook">
              <span>Hook</span>
              <textarea
                id="image-hook"
                name="imageHook"
                placeholder="A musician portrait made after the room emptied out."
              ></textarea>
              <span class="copy-muted block">
                Keep this short. It shows up in cards and previews.
              </span>
            </label>

            <label class="space-y-2 text-sm text-paper" for="image-story">
              <span>Story</span>
              <textarea
                id="image-story"
                name="imageStory"
                placeholder="Two to four sentences of context for the image page."
              ></textarea>
              <span class="copy-muted block">
                Use direct context for the individual image page.
              </span>
            </label>

            <fieldset class="space-y-3">
              <legend class="text-sm font-semibold text-paper">Orientation</legend>
              <p class="copy-muted">
                These labels map to the current schema values. Leave it unset for panorama or unusual custom crops.
              </p>
              <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                <label class="flex h-full cursor-pointer flex-col gap-2 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-paper">
                  <input checked class="h-4 w-4" name="imageOrientation" type="radio" value="" />
                  <span class="font-semibold">Not set</span>
                  <span class="copy-muted text-xs">
                    Use when the crop is unusual and you do not want to force a schema value.
                  </span>
                </label>

                <label class="flex h-full cursor-pointer flex-col gap-2 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-paper">
                  <input class="h-4 w-4" name="imageOrientation" type="radio" value="vertical" />
                  <span class="font-semibold">Portrait</span>
                  <span class="copy-muted text-xs">
                    Stores <code>vertical</code> for tall, portrait-oriented images.
                  </span>
                </label>

                <label class="flex h-full cursor-pointer flex-col gap-2 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-paper">
                  <input class="h-4 w-4" name="imageOrientation" type="radio" value="horizontal" />
                  <span class="font-semibold">Landscape</span>
                  <span class="copy-muted text-xs">
                    Stores <code>horizontal</code> for wide, landscape-oriented images.
                  </span>
                </label>

                <label class="flex h-full cursor-pointer flex-col gap-2 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-paper">
                  <input class="h-4 w-4" name="imageOrientation" type="radio" value="square" />
                  <span class="font-semibold">Square</span>
                  <span class="copy-muted text-xs">
                    Stores <code>square</code> for 1:1 images and crops.
                  </span>
                </label>
              </div>
            </fieldset>

            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
              <label class="space-y-2 text-sm text-paper" for="image-year">
                <span>Year</span>
                <input id="image-year" name="imageYear" placeholder="2026" type="text" />
              </label>

              <label class="space-y-2 text-sm text-paper" for="image-location">
                <span>Location</span>
                <input id="image-location" name="imageLocation" placeholder="Nashville, Tennessee" type="text" />
              </label>

              <label class="space-y-2 text-sm text-paper" for="image-medium">
                <span>Medium</span>
                <input id="image-medium" name="imageMedium" placeholder="Digital photograph" type="text" />
              </label>

              <label class="space-y-2 text-sm text-paper" for="image-best-format">
                <span>Best format note</span>
                <input
                  id="image-best-format"
                  name="imageBestFormat"
                  placeholder="Large horizontal print"
                  type="text"
                />
              </label>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="space-y-2 text-sm text-paper" for="image-service-cta">
                <span>Service CTA</span>
                <select id="image-service-cta" name="imageServiceCta">
                  <option value="">None</option>
                  <option value="portrait">Portrait</option>
                  <option value="legacy">Legacy</option>
                  <option value="musician">Musician</option>
                  <option value="custom">Custom</option>
                </select>
                <span class="copy-muted block">
                  Choose the inquiry path that best matches this image.
                </span>
              </label>
            </div>

            <div class="grid gap-4 sm:grid-cols-3">
              <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-paper">
                <input class="h-4 w-4" id="image-featured" name="imageFeatured" type="checkbox" />
                Featured image
              </label>

              <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-paper">
                <input class="h-4 w-4" id="image-print-available" name="imagePrintAvailable" type="checkbox" />
                Print available
              </label>

              <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-paper">
                <input class="h-4 w-4" id="create-product" name="createProduct" type="checkbox" />
                Create product entry
              </label>
            </div>
          </section>

          <section class="space-y-5 border-t border-white/10 pt-8">
            <div class="space-y-2">
              <h2 class="text-2xl">Product</h2>
              <p class="copy-muted">
                Enable this only when the image should also appear in <code>src/data/products.ts</code>.
              </p>
            </div>

            <fieldset class="space-y-5 opacity-60" disabled id="product-fields">
              <div class="grid gap-5 sm:grid-cols-2">
                <label class="space-y-2 text-sm text-paper" for="product-title">
                  <span>Product title</span>
                  <input id="product-title" name="productTitle" placeholder="After the Show" type="text" />
                </label>

                <label class="space-y-2 text-sm text-paper" for="product-slug">
                  <span>Product slug</span>
                  <input id="product-slug" name="productSlug" placeholder="after-the-show-print" type="text" />
                </label>
              </div>

              <label class="space-y-2 text-sm text-paper" for="product-description">
                <span>Short description</span>
                <textarea
                  id="product-description"
                  name="productDescription"
                  placeholder="A post-performance portrait built for buyers who want a print with residue and atmosphere."
                ></textarea>
              </label>

              <fieldset class="space-y-3">
                <legend class="text-sm font-semibold text-paper">Selectable print sizes</legend>
                <p class="copy-muted">
                  These choices populate the <code>availableFormats</code> array in <code>products.ts</code>.
                </p>
                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                  {
                    ['8 x 10', '11 x 14', '12 x 18', '16 x 20', '16 x 24', '20 x 30', '24 x 36'].map(
                      (size) => (
                        <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-paper">
                          <input class="h-4 w-4" name="productFormatPreset" type="checkbox" value={size} />
                          {size}
                        </label>
                      ),
                    )
                  }
                </div>
              </fieldset>

              <div class="grid gap-5 sm:grid-cols-2">
                <label class="space-y-2 text-sm text-paper" for="product-custom-sizes">
                  <span>Custom sizes</span>
                  <input
                    id="product-custom-sizes"
                    name="productCustomSizes"
                    placeholder="30 x 40, 40 x 60"
                    type="text"
                  />
                  <span class="copy-muted block">
                    Add any extra sizes as comma-separated values.
                  </span>
                </label>

                <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-paper sm:self-end">
                  <input class="h-4 w-4" id="product-inquiry-allowed" name="productInquiryAllowed" type="checkbox" />
                  Allow custom print inquiry
                </label>
              </div>
            </fieldset>
          </section>

          <section class="space-y-5 border-t border-white/10 pt-8">
            <div class="space-y-2">
              <h2 class="text-2xl">Outbound links</h2>
              <p class="copy-muted">
                Add only the storefronts you want to use for this image or product.
              </p>
            </div>

            <fieldset class="space-y-3" id="shared-route-keys-fieldset">
              <legend class="text-sm font-semibold text-paper">Shared route keys</legend>
              <p class="copy-muted">
                Include selected route keys when this product should use shared storefront placeholders.
              </p>
              <div class="grid gap-3 sm:grid-cols-2">
                <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-paper">
                  <input class="h-4 w-4" name="routeKey" type="checkbox" value="fineArtAmerica" />
                  Fine Art America
                </label>

                <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-paper">
                  <input class="h-4 w-4" name="routeKey" type="checkbox" value="etsy" />
                  Etsy
                </label>

                <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-paper">
                  <input class="h-4 w-4" name="routeKey" type="checkbox" value="shopify" />
                  Shopify
                </label>

                <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-paper">
                  <input class="h-4 w-4" name="routeKey" type="checkbox" value="pixieset" />
                  Pixieset
                </label>
              </div>
            </fieldset>

            <div class="grid gap-5">
              <label class="space-y-2 text-sm text-paper" for="fine-art-america-url">
