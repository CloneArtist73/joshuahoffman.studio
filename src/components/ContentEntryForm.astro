  const seedExternalLinks = seedData.externalLinks && typeof seedData.externalLinks === 'object' ? seedData.externalLinks : {};
  const seedImageBySlug = new Map(seedImages.map((image) => [image?.slug, image || {}]));
  const seedProductBySlug = new Map(seedProducts.map((product) => [product?.slug, product || {}]));
  const seedProductByImageSlug = new Map(seedProducts.map((product) => [product?.imageSlug, product || {}]));
  const sharedPlatformKeys = new Set(routePlatformFields.map((entry) => entry.sharedKey));
  const knownDirectSuffixes = routePlatformFields.map((entry) => entry.suffix).concat(['Other']);

  let currentMode = 'file-import';
  let selectedOriginalImageSlug = '';
  let selectedOriginalProductSlug = '';
  let selectedImageRecord = null;
  let selectedProductRecord = null;

  const formatPresets = ['8 x 10', '11 x 14', '12 x 18', '16 x 20', '16 x 24', '20 x 30', '24 x 36'];
  const imageCategories = ['portrait', 'legacy', 'musician', 'print', 'personal'];
  const orientations = ['vertical', 'horizontal', 'square'];
  const serviceCtas = ['portrait', 'legacy', 'musician', 'custom'];
  const aiReviewSchema = {
    type: 'object',
    properties: {
      title: { type: 'string' },
      category: { type: 'string', enum: imageCategories },
      tags: { type: 'array', items: { type: 'string' } },
      alt: { type: 'string' },
      hook: { type: 'string' },
      story: { type: 'string' },
      orientation: { type: 'string', enum: orientations },
      medium: { type: 'string' },
      bestFormat: { type: 'string' },
      serviceCTA: { type: 'string', enum: serviceCtas },
      productShortDescription: { type: 'string' },
      productFormats: { type: 'array', items: { type: 'string' } },
      cautions: { type: 'array', items: { type: 'string' } },
    },
    required: ['title', 'category', 'tags', 'alt', 'hook', 'story', 'orientation', 'medium', 'bestFormat', 'serviceCTA', 'productShortDescription', 'productFormats', 'cautions'],
  };
  const aiPromptConfig = JSON.parse(aiPromptConfigElement?.textContent || '{}');
  const aiRequestTimeoutMs = 90000;
  const aiVisionRequestTimeoutMs = 240000;
  const aiHealthTimeoutMs = 6000;
  const aiReviewMaxDimension = 1600;
  const aiReviewJpegQuality = 0.86;
  const aiProviderConfig = {
    ollama: {
      endpoint: aiPromptConfig.ollamaEndpointDefault || aiPromptConfig.endpointDefault || 'http://localhost:11434',
      help: 'Ollama is used for image scans when a vision model is installed and running.',
      modelMeta: 'Refresh models after Ollama is running. Choose a vision-capable model.',
      startLabel: 'Start Ollama (terminal)',
      canStartFromBrowser: false,
    },
    promptforge: {
      endpoint: aiPromptConfig.promptForgeEndpointDefault || 'http://127.0.0.1:5000',
      help: 'PromptForge can launch its local text LLM. Image scanning needs a PromptForge image-review endpoint before this form can use it.',
      modelMeta: 'Choose the PromptForge local LLM launch target. These are not image-review models.',
      startLabel: 'Launch PromptForge LLM',
      canStartFromBrowser: true,
    },
  };
  const promptForgeLaunchModels = Array.isArray(aiPromptConfig.promptForgeLaunchModels)
    ? aiPromptConfig.promptForgeLaunchModels
    : [];
  const ollamaModelPresets = Array.isArray(aiPromptConfig.ollamaModelPresets)
    ? aiPromptConfig.ollamaModelPresets
    : [
        { label: 'Gemma 4 e4b (recommended)', value: 'gemma4:e4b', note: 'Balanced quality and speed. About 10 GB.' },
        { label: 'Gemma 4 e2b (lighter)', value: 'gemma4:e2b', note: 'Lower resource option. About 7-8 GB.' },
        { label: 'Gemma 4 26b (higher quality)', value: 'gemma4:26b', note: 'Higher quality, heavier runtime. About 18 GB.' },
        { label: 'Gemma 4 31b (max quality)', value: 'gemma4:31b', note: 'Best quality, largest runtime. About 20 GB.' },
        { label: 'Qwen 2.5 VL 7B (alternate)', value: 'qwen2.5vl:7b', note: 'Strong visual parsing, about 6 GB.' },
      ];
  const visionModelHints = [
    'vision',
    'vl',
    'llava',
    'bakllava',
    'moondream',
    'minicpm',
    'qwen2vl',
    'qwen2.5vl',
    'gemma3',
    'gemma4',
    'llama3.2-vision',
  ];
  const aiSuggestionFields = [
    { key: 'title', label: 'Title', targetId: 'image-title', type: 'text' },
    { key: 'category', label: 'Category', targetId: 'image-category', type: 'select' },
    { key: 'tags', label: 'Tags', targetId: 'image-tags', type: 'list' },
    { key: 'alt', label: 'Alt text', targetId: 'image-alt', type: 'text' },
    { key: 'hook', label: 'Hook', targetId: 'image-hook', type: 'text' },
    { key: 'story', label: 'Story', targetId: 'image-story', type: 'text' },
    { key: 'orientation', label: 'Orientation', targetName: 'imageOrientation', type: 'radio' },
    { key: 'medium', label: 'Medium', targetId: 'image-medium', type: 'text' },
    { key: 'bestFormat', label: 'Best format note', targetId: 'image-best-format', type: 'text' },
    { key: 'serviceCTA', label: 'Service CTA', targetId: 'image-service-cta', type: 'select' },
    {
      key: 'productShortDescription',
      label: 'Product description',
      targetId: 'product-description',
      type: 'productText',
      defaultChecked: false,
    },
    {
      key: 'productFormats',
      label: 'Product formats',
      targetId: 'product-custom-sizes',
      type: 'productList',
      defaultChecked: false,
    },
  ];

  const fsApiSupported =
    window.isSecureContext &&
    'showDirectoryPicker' in window &&
    'FileSystemDirectoryHandle' in window;

  let selectedImageFile = null;
  let selectedProjectDirectory = null;
  let selectedPreviewUrl = '';
  let activeModelPresets = [];
  let discoveredOllamaModels = [];
  let latestAiReviewInputContext = '';

  function getDirectKeySuffixes() {
    return [...knownDirectSuffixes];
  }

  function isImageDirectKeyForBase(key, imageSlug) {
    return getDirectKeySuffixes().some((suffix) => key === `${getImageBaseFromSlug(imageSlug || '')}${suffix}`);
  }

  function getImageBaseFromSlug(imageSlug) {
    return slugToCamel(imageSlug || 'image');
  }

  function buildDirectKey(imageSlug, suffix) {
    return `${getImageBaseFromSlug(imageSlug)}${suffix}`;
  }

  function asMapKey(value) {
    return String(value || '').trim();
  }

  function escapeRegExp(value) {
    return asMapKey(value).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function getDirectPlatformForRouteKey(key, imageSlug) {
    const imageBase = getImageBaseFromSlug(imageSlug || '');
    if (!imageBase || !key.startsWith(imageBase)) {
      return 'other';
    }

    const suffix = key.slice(imageBase.length);
    if (!suffix) {
      return 'other';
    }

    const directField = routePlatformBySuffix.get(suffix);
    return directField?.sharedKey || 'other';
  }

  function getActiveMode() {
    return currentMode === 'edit-gallery' ? 'edit-gallery' : 'file-import';
  }

  function normalizeRecordValue(value) {
    return value && typeof value === 'object' ? value : null;
  }

  function clearInputValue(targetId) {
    const target = document.getElementById(targetId);
    if (!target) {
      return;
    }

    if (target.type === 'checkbox') {
      target.checked = false;
      return;
    }

    target.value = '';
  }

  function clearImageModeState(resetMode = false) {
    if (resetMode) {
      selectedOriginalImageSlug = '';
      selectedOriginalProductSlug = '';
      selectedImageRecord = null;
      selectedProductRecord = null;
      if (editImageSelect) {
        editImageSelect.value = '';
      }
      if (editImageMeta) {
        editImageMeta.textContent = 'Select a current gallery image to pre-fill image and product fields.';
      }
    }

    selectedImageFile = null;
    fileInput.value = '';
    updateFileMeta();
    updatePreviewImage();
  }

  function getEffectiveCreateProductState() {
    return (
      Boolean(form?.querySelector('input[name=\"createProduct\"]')?.checked) ||
      (currentMode === 'edit-gallery' &&
        Boolean(
          selectedProductRecord ||
            selectedOriginalProductSlug ||
            (selectedImageRecord?.productSlug && selectedOriginalImageSlug),
        ))
    );
  }

  function getEditModeProductRecord() {
    if (currentMode !== 'edit-gallery') {
      return null;
    }

    if (selectedImageRecord) {
      return getSeedProductRecord(selectedImageRecord.slug, selectedImageRecord.productSlug) || selectedProductRecord;
    }

    return selectedProductRecord;
  }

  function getCurrentImageRecord() {
    if (selectedOriginalImageSlug) {
      return seedImageBySlug.get(selectedOriginalImageSlug) || selectedImageRecord || null;
    }

    return selectedImageRecord;
  }

  function getEditSelectionProductRecord() {
    if (selectedOriginalProductSlug && seedProductBySlug.has(selectedOriginalProductSlug)) {
      return seedProductBySlug.get(selectedOriginalProductSlug) || null;
    }

    if (!selectedOriginalImageSlug) {
      return null;
    }

    return seedProductByImageSlug.get(selectedOriginalImageSlug) || null;
  }

  function clearEditFormFields() {
    setValue('image-title', '');
    setValue('image-slug', '');
    setValue('image-src', '');
    setValue('image-category', 'portrait');
    setValue('image-tags', '');
    setValue('image-alt', '');
    setValue('image-hook', '');
    setValue('image-story', '');
    setValue('image-year', '');
    setValue('image-location', '');
    setValue('image-medium', '');
    setValue('image-best-format', '');
    setValue('image-service-cta', '');

    const notSetOrientation = form.querySelector('input[name=\"imageOrientation\"][value=\"\"]');
    if (notSetOrientation) {
      notSetOrientation.checked = true;
    }

    const featuredInput = document.getElementById('image-featured');
    if (featuredInput) {
      featuredInput.checked = false;
    }

    printAvailableCheckbox.checked = false;
    setValue('image-print-available', false);
    updateProductSectionFromRecord(null);
    clearSharedRouteKeysInForm();
    clearInputValue('fine-art-america-url');
    clearInputValue('etsy-url');
    clearInputValue('shopify-url');
    clearInputValue('pixieset-url');
    clearInputValue('other-label');
    clearInputValue('other-url');
  }

  function setFormFromImageRecord(record) {
    const sourceRecord = normalizeRecordValue(record);
    if (!sourceRecord) {
      return;
    }

    slugInput.dataset.dirty = '';
    productSlugInput.dataset.dirty = '';
    productTitleInput.dataset.dirty = '';

    setValue('image-title', String(sourceRecord.title || '').trim());
    setValue('image-slug', String(sourceRecord.slug || '').trim());
    setValue('image-src', String(sourceRecord.imageSrc || '').trim());
    setValue('image-category', String(sourceRecord.category || 'portrait').trim());
    setValue('image-tags', Array.isArray(sourceRecord.tags) ? sourceRecord.tags.join(', ') : '');
    setValue('image-alt', String(sourceRecord.alt || '').trim());
    setValue('image-hook', String(sourceRecord.hook || '').trim());
    setValue('image-story', String(sourceRecord.story || '').trim());
    setValue('image-year', String(sourceRecord.year || '').trim());
    setValue('image-location', String(sourceRecord.location || '').trim());
    setValue('image-medium', String(sourceRecord.medium || '').trim());
    setValue('image-best-format', String(sourceRecord.bestFormat || '').trim());
    setValue('image-service-cta', String(sourceRecord.serviceCTA || '').trim());

    const orientation = String(sourceRecord.orientation || '');
    const orientationInput = form.querySelector(`input[name=\"imageOrientation\"][value=\"${orientation}\"]`);
    if (orientationInput) {
      orientationInput.checked = true;
    } else {
      const notSet = form.querySelector('input[name=\"imageOrientation\"][value=\"\"]');
      if (notSet) {
        notSet.checked = true;
      }
    }

    printAvailableCheckbox.checked = Boolean(sourceRecord.printAvailable);
    const featuredInput = document.getElementById('image-featured');
    if (featuredInput) {
      featuredInput.checked = Boolean(sourceRecord.featured);
    }

    updateProductSectionFromRecord(currentMode === 'edit-gallery' ? getSeedProductRecord(sourceRecord.slug, sourceRecord.productSlug) : null);
  }

  function getFormattedProductFromRecord(productRecord) {
    const sourceRecord = normalizeRecordValue(productRecord);
    if (!sourceRecord) {
      return null;
    }

    return {
      slug: String(sourceRecord.slug || ''),
      imageSlug: String(sourceRecord.imageSlug || ''),
      title: String(sourceRecord.title || ''),
      shortDescription: String(sourceRecord.shortDescription || ''),
      availableFormats: Array.isArray(sourceRecord.availableFormats) ? sourceRecord.availableFormats : [],
      routeKeys: Array.isArray(sourceRecord.routeKeys) ? sourceRecord.routeKeys : [],
      inquiryAllowed: Boolean(sourceRecord.inquiryAllowed),
    };
  }

  function updateProductSectionFromRecord(productRecord) {
    const product = getFormattedProductFromRecord(productRecord);
    selectedProductRecord = product || null;
    selectedOriginalProductSlug = product?.slug || '';

    const directUrlInputIds = [
      'fine-art-america-url',
      'etsy-url',
      'shopify-url',
      'pixieset-url',
    ];
    for (const directInputId of directUrlInputIds) {
      clearInputValue(directInputId);
    }
    clearInputValue('other-label');
    clearInputValue('other-url');

    const currentImageSlug = selectedOriginalImageSlug || selectedImageRecord?.slug || product?.imageSlug || '';

    const productFormatCheckboxes = Array.from(form.querySelectorAll('input[name=\"productFormatPreset\"]'));

    if (!product) {
      createProductCheckbox.checked = false;
      productTitleInput.value = '';
      productSlugInput.value = '';
      clearInputValue('product-description');
      clearInputValue('product-custom-sizes');
      for (const checkbox of productFormatCheckboxes) {
        checkbox.checked = false;
      }
      clearInputValue('product-inquiry-allowed');
      return;
    }

    createProductCheckbox.checked = true;
    setValue('product-title', product.title);
    setValue('product-slug', product.slug);
    setValue('product-description', product.shortDescription);
    for (const checkbox of productFormatCheckboxes) {
      checkbox.checked = false;
    }
    for (const preset of product.availableFormats) {
      const presetBox = form.querySelector(`input[name=\"productFormatPreset\"][value=\"${preset}\"]`);
      if (presetBox) {
        presetBox.checked = true;
      }
    }
    const knownPresetSizes = new Set(['8 x 10', '11 x 14', '12 x 18', '16 x 20', '16 x 24', '20 x 30', '24 x 36']);
    const customSizes = product.availableFormats.filter((format) => !knownPresetSizes.has(format));
    setValue('product-custom-sizes', customSizes.join(', '));
    setValue('product-inquiry-allowed', product.inquiryAllowed);
    setSharedRouteKeysInForm(product.routeKeys);

    const directKeys = Array.isArray(product.routeKeys)
      ? product.routeKeys.filter((routeKey) =>
          isImageDirectKeyForBase(routeKey, currentImageSlug),
        )
      : [];
    let otherLabel = '';
    let otherUrl = '';

    for (const routeKey of directKeys) {
      const routeEntry = normalizeRecordValue(seedExternalLinks[routeKey]) || {};
      const url = String(routeEntry.url || '').trim();
      const platformKey = getDirectPlatformForRouteKey(routeKey, currentImageSlug);
      if (platformKey !== 'other') {
        const fieldId = routeFieldIdBySharedKey.get(platformKey);
        if (fieldId && url) {
          setValue(fieldId, url);
        }
        continue;
      }

      if (!url && !routeEntry.label) {
        continue;
      }

      if (!otherLabel && routeEntry.label) {
        otherLabel = String(routeEntry.label).trim();
      }
      if (!otherUrl && routeEntry.url) {
        otherUrl = String(routeEntry.url).trim();
      }
    }

    if (otherLabel) {
      setValue('other-label', otherLabel);
    }
    if (otherUrl) {
      setValue('other-url', otherUrl);
    }

    clearInputValue('product-slug');
    if (product.slug) {
      setValue('product-slug', product.slug);
    }
    setValue('product-title', product.title);
  }

  function getSeedProductRecord(imageSlug, productSlug) {
    if (productSlug && seedProductBySlug.has(productSlug)) {
      return seedProductBySlug.get(productSlug) || null;
    }

    if (imageSlug && selectedImageRecord?.slug === imageSlug) {
      const productFromImage = seedProductByImageSlug.get(imageSlug);
      if (productFromImage) {
        return productFromImage;
      }
    }

    if (selectedOriginalProductSlug) {
      return seedProductBySlug.get(selectedOriginalProductSlug) || null;
    }

    if (imageSlug) {
      return seedProductByImageSlug.get(imageSlug) || null;
    }

    return null;
  }

  function refreshModeTabs(targetMode, { announce = true } = {}) {
    currentMode = targetMode === 'edit-gallery' ? 'edit-gallery' : 'file-import';

    const isEditMode = currentMode === 'edit-gallery';
    const activeFileLabel = isEditMode ? 'Replace image file (optional)' : 'Choose image file';
    if (modeFileLabel) {
      modeFileLabel.textContent = activeFileLabel;
    }

    const fileControlsParent = isEditMode ? editGalleryPanel : fileImportPanel;
    if (localFileControls && fileControlsParent && localFileControls.parentElement !== fileControlsParent) {
      fileControlsParent.append(localFileControls);
    }

    for (const button of tabButtons) {
      const selected = button.getAttribute('data-entry-tab') === currentMode;
      button.classList.toggle('bg-obsidian/70', selected);
      button.classList.toggle('border-emerald-500/50', selected);
      button.classList.toggle('bg-white/5', !selected);
      button.setAttribute('aria-selected', selected ? 'true' : 'false');
    }

    for (const panel of entryPanels) {
      const selected = panel.getAttribute('data-entry-panel') === currentMode;
      panel.classList.toggle('hidden', !selected);
    }

    if (announce) {
      setStatus(
        isEditMode
          ? 'Edit gallery mode active. Select an existing image to pre-fill editable fields.'
          : 'File import mode active. Use this form to add a new image.',
        isEditMode ? 'warning' : 'success',
      );
    }

    if (submitButton) {
      submitButton.textContent = isEditMode ? 'Update Gallery Entry' : 'Add Locally';
      submitButton.classList.toggle('bg-sage', isEditMode);
      submitButton.classList.toggle('bg-ember', !isEditMode);
      submitButton.classList.toggle('hover:bg-[#d48b63]', !isEditMode);
      submitButton.classList.toggle('hover:bg-[#b5c7b7]', isEditMode);
      if (!isEditMode) {
        submitButton.classList.add('border-ember/70');
        submitButton.classList.remove('border-sage/70');
      } else {
        submitButton.classList.add('border-sage/70');
        submitButton.classList.remove('border-ember/70');
      }
    }

    updateSupportMessage();
    updateFileMeta();
    updatePreviewImage();
    updateOutputs();
  }

  function populateEditGallerySelect() {
    if (!editImageSelect) {
      return;
    }

    const currentValue = editImageSelect.value;
    editImageSelect.innerHTML = '<option value=\"\">Choose an image to edit</option>';

    const sortedImages = [...seedImages]
      .filter((image) => image?.slug && image?.title)
      .sort((a, b) => String(a.title).localeCompare(String(b.title)));

    for (const image of sortedImages) {
      const option = document.createElement('option');
      option.value = String(image.slug);
      option.textContent = `${String(image.title)} (${String(image.slug)})`;
      editImageSelect.append(option);
    }

    if (currentMode === 'edit-gallery' && seedImageBySlug.has(currentValue)) {
      editImageSelect.value = currentValue;
    }
  }

  function applyEditImageSelection() {
    if (!editImageSelect) {
      return;
    }

    const selectedImageSlug = String(editImageSelect.value || '').trim();
    if (!selectedImageSlug) {
      clearImageModeState();
      selectedOriginalImageSlug = '';
      selectedImageRecord = null;
      selectedProductRecord = null;
      selectedOriginalProductSlug = '';
      selectedImageFile = null;
      if (editImageMeta) {
        editImageMeta.textContent = 'Select a current gallery image to pre-fill image and product fields.';
      }
      setValue('image-slug', '');
      setValue('image-title', '');
      setValue('image-src', '');
      clearEditFormFields();
      updateFileMeta();
      updatePreviewImage();
      return;
    }

    const imageRecord = normalizeRecordValue(seedImageBySlug.get(selectedImageSlug));
    if (!imageRecord) {
      setStatus('Could not load the selected image from seed data. Refresh the page and try again.', 'error', { reveal: true });
      return;
    }

    selectedOriginalImageSlug = selectedImageSlug;
    selectedImageRecord = imageRecord;
    selectedOriginalProductSlug = '';
    selectedImageFile = null;
    setFormFromImageRecord(imageRecord);
    setValue('image-title', String(imageRecord.title || '').trim());
    updateOutputs();
    updateFileMeta();
    updatePreviewImage();
    if (imageRecord.imageSrc) {
      editImageMeta.textContent = `Editing ${selectedImageSlug}. Path: ${imageRecord.imageSrc}`;
    }
  }

  function setValue(targetId, value) {
    const target = document.getElementById(targetId);
    if (!target) {
      return;
    }

    if (target.type === 'checkbox') {
      target.checked = Boolean(value);
    } else {
      target.value = value;
    }
    target.dispatchEvent(new Event('input', { bubbles: true }));
    target.dispatchEvent(new Event('change', { bubbles: true }));
  }

  function getSharedRouteKeysFromForm() {
    return sharedRouteCheckboxes
      .filter((checkbox) => checkbox.checked && sharedPlatformKeys.has(checkbox.value))
      .map((checkbox) => checkbox.value);
  }

  function setSharedRouteKeysInForm(routeKeys) {
    const sharedKeys = new Set(routeKeys.filter((key) => sharedPlatformKeys.has(key)));
    for (const checkbox of sharedRouteCheckboxes) {
      checkbox.checked = sharedKeys.has(checkbox.value);
    }
  }

  function clearSharedRouteKeysInForm() {
    for (const checkbox of sharedRouteCheckboxes) {
      checkbox.checked = false;
    }
  }

  function slugify(value) {
    return value
      .toLowerCase()
      .trim()
      .replace(/['"]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
  }

  function slugToCamel(value) {
    return value
      .split('-')
      .filter(Boolean)
      .map((segment, index) =>
        index === 0 ? segment : `${segment.charAt(0).toUpperCase()}${segment.slice(1)}`,
      )
      .join('');
  }

  function splitList(value) {
    return value
      .split(',')
      .map((item) => item.trim())
      .filter(Boolean);
  }

  function uniqueList(items) {
    return [...new Set(items.filter(Boolean))];
  }

  function escapeString(value) {
    return String(value)
      .replace(/\\/g, '\\\\')
      .replace(/'/g, "\\'")
      .replace(/\r?\n/g, '\\n');
  }

  function quoted(value) {
    return `'${escapeString(value)}'`;
  }

  function arrayLine(key, items, indent = '  ') {
    if (!items.length) {
      return `${indent}${key}: [],`;
    }

    return `${indent}${key}: [${items.map((item) => quoted(item)).join(', ')}],`;
  }

  function pushString(lines, key, value) {
    if (value) {
      lines.push(`  ${key}: ${quoted(value)},`);
    }
  }

  function pushBoolean(lines, key, value) {
    if (value) {
      lines.push(`  ${key}: true,`);
    }
  }

  function applyStatusStyle(target, variant) {
    target.classList.remove(
      'hidden',
      'border-emerald-400/30',
      'bg-emerald-400/10',
      'text-paper',
      'border-amber-400/30',
      'bg-amber-400/10',
      'border-rose-400/30',
      'bg-rose-400/10',
    );

    if (variant === 'success') {
      target.classList.add('border-emerald-400/30', 'bg-emerald-400/10', 'text-paper');
    } else if (variant === 'warning') {
      target.classList.add('border-amber-400/30', 'bg-amber-400/10', 'text-paper');
    } else {
      target.classList.add('border-rose-400/30', 'bg-rose-400/10', 'text-paper');
    }
  }

  function revealStatus(target) {
    target.setAttribute('tabindex', '-1');
    target.focus({ preventScroll: true });
    target.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function setStatus(message, variant, { reveal = false } = {}) {
    statusElement.textContent = message;
    applyStatusStyle(statusElement, variant);

    if (reveal) {
      submitStatusElement.textContent = message;
      applyStatusStyle(submitStatusElement, variant);
      revealStatus(submitStatusElement);
    } else {
      submitStatusElement.textContent = '';
      submitStatusElement.classList.add('hidden');
    }
  }

  function clearStatus() {
    statusElement.textContent = '';
    statusElement.classList.add('hidden');
    submitStatusElement.textContent = '';
    submitStatusElement.classList.add('hidden');
  }

  function setAiStatus(message, variant) {
    aiReviewStatus.textContent = message;
    aiReviewStatus.classList.remove(
      'hidden',
      'border-emerald-400/30',
      'bg-emerald-400/10',
      'text-paper',
      'border-amber-400/30',
      'bg-amber-400/10',
      'border-rose-400/30',
      'bg-rose-400/10',
    );

    if (variant === 'success') {
      aiReviewStatus.classList.add('border-emerald-400/30', 'bg-emerald-400/10', 'text-paper');
      return;
    }

    if (variant === 'warning') {
      aiReviewStatus.classList.add('border-amber-400/30', 'bg-amber-400/10', 'text-paper');
      return;
    }

    aiReviewStatus.classList.add('border-rose-400/30', 'bg-rose-400/10', 'text-paper');
  }

  function clearAiStatus() {
    aiReviewStatus.textContent = '';
    aiReviewStatus.classList.add('hidden');
  }

  function getAiProvider() {
    return aiProviderSelect.value === 'promptforge' ? 'promptforge' : 'ollama';
  }

  function getAiEndpoint() {
    return aiEndpointInput.value.trim().replace(/\/+$/, '');
  }

  function timeoutSignal(timeoutMs) {
    const controller = new AbortController();
    const timeoutId = window.setTimeout(() => controller.abort(), timeoutMs);
    return { controller, timeoutId };
  }

  function normalizeModelEntries(models) {
    if (!Array.isArray(models)) {
      return [];
    }

    return models
      .map((model) => {
        if (!model) {
          return null;
        }

        if (typeof model === 'string') {
          const value = model.trim();
          return value ? { label: value, value, note: '' } : null;
        }

        const value = String(model.value || model.model || model.name || '').trim();
        if (!value) {
          return null;
        }

        return {
          label: String(model.label || value).trim() || value,
          value,
          note: String(model.note || '').trim(),
        };
      })
      .filter(Boolean);
  }

  function populateAiModelOptions(models) {
    aiModelOptions.innerHTML = '';

    for (const model of normalizeModelEntries(models)) {
      const option = document.createElement('option');
      option.value = model.value;
      option.label = model.label || model.value;
      aiModelOptions.append(option);
    }
  }

  function mergeUniqueModelEntries(...lists) {
    const merged = [];
    const seenValues = new Set();

    for (const list of lists) {
      for (const entry of normalizeModelEntries(list)) {
        if (seenValues.has(entry.value)) {
          continue;
        }
        seenValues.add(entry.value);
        merged.push(entry);
      }
    }

    return merged;
  }

  function normalizeModelName(value) {
    return String(value || '').trim().toLowerCase();
  }

  function canonicalModelName(value) {
    const normalized = normalizeModelName(value);
    if (!normalized) {
      return '';
    }

    return normalized.endsWith(':latest') ? normalized.slice(0, -':latest'.length) : normalized;
  }

  function isLikelyVisionModelName(value) {
    const normalized = canonicalModelName(value);
    if (!normalized) {
      return false;
    }

    if (visionModelHints.some((hint) => normalized.includes(hint))) {
      return true;
    }

    return /(^|[:/_-])(vision|vl)([:/_-]|$)/.test(normalized);
  }

  function isInstalledModelName(selectedModel, installedModels) {
    const selectedCanonical = canonicalModelName(selectedModel);
    if (!selectedCanonical) {
      return false;
    }

    return installedModels.some((installedModel) => canonicalModelName(installedModel) === selectedCanonical);
  }

  function summarizeModelNames(modelNames, maxCount = 3) {
    const cleaned = modelNames.map((name) => String(name || '').trim()).filter(Boolean);
    if (!cleaned.length) {
      return '';
    }

    const preview = cleaned.slice(0, maxCount).join(', ');
    return cleaned.length > maxCount ? `${preview}, +${cleaned.length - maxCount} more` : preview;
  }

  function populateModelPresetOptions(presets) {
    activeModelPresets = normalizeModelEntries(presets);
    aiModelPresetSelect.innerHTML = '';

    const customOption = document.createElement('option');
    customOption.value = '';
    customOption.textContent = 'Custom model name (typed)';
    aiModelPresetSelect.append(customOption);

    for (const preset of activeModelPresets) {
      const option = document.createElement('option');
      option.value = preset.value;
      option.textContent = preset.label;
      if (preset.note) {
        option.dataset.note = preset.note;
      }
      aiModelPresetSelect.append(option);
    }
  }

  function syncModelPresetToInput() {
    const selectedValue = aiModelPresetSelect.value;
    if (!selectedValue) {
      aiModelPresetHint.textContent = 'Choose a preset to fill the model name quickly, or type a custom value.';
      return;
    }

    aiModelInput.value = selectedValue;
    const selectedOption = aiModelPresetSelect.selectedOptions[0];
    aiModelPresetHint.textContent = selectedOption?.dataset.note || 'Preset selected.';
  }

  function syncInputToModelPreset() {
    const typedValue = aiModelInput.value.trim();
    if (!typedValue) {
      aiModelPresetSelect.value = '';
      aiModelPresetHint.textContent = 'Choose a preset to fill the model name quickly, or type a custom value.';
      return;
    }

    const matchedPreset = activeModelPresets.find((preset) => preset.value === typedValue);
    if (!matchedPreset) {
      aiModelPresetSelect.value = '';
      aiModelPresetHint.textContent = 'Using a custom model name.';
      return;
    }

    aiModelPresetSelect.value = matchedPreset.value;
    aiModelPresetHint.textContent = matchedPreset.note || 'Preset selected.';
  }

  function applyAiProviderDefaults({ resetEndpoint = false, resetModel = false } = {}) {
    const provider = getAiProvider();
    const config = aiProviderConfig[provider];

    if (resetEndpoint || !aiEndpointInput.value.trim()) {
      aiEndpointInput.value = config.endpoint;
    }

    aiProviderHelp.textContent = config.help;
    aiModelMeta.textContent = config.modelMeta;
    aiStartButton.textContent = config.startLabel;
    aiStartButton.disabled = !config.canStartFromBrowser;
    aiStartButton.title = config.canStartFromBrowser
      ? ''
      : 'Run `ollama serve` in your terminal, then return here and click Refresh Models.';

    if (provider === 'promptforge') {
      populateModelPresetOptions(promptForgeLaunchModels);
      populateAiModelOptions(promptForgeLaunchModels);
      if (resetModel || !aiModelInput.value.trim()) {
        aiModelInput.value = promptForgeLaunchModels[0]?.value || 'qwen';
      }
      syncInputToModelPreset();
      return;
    }

    populateModelPresetOptions(ollamaModelPresets);
    populateAiModelOptions(ollamaModelPresets);
    if (resetModel) {
      aiModelInput.value = '';
    }
    syncInputToModelPreset();
  }

  async function fetchJsonWithTimeout(url, options = {}, timeoutMs = aiHealthTimeoutMs) {
    const { controller, timeoutId } = timeoutSignal(timeoutMs);

    try {
      const response = await fetch(url, {
        ...options,
        signal: controller.signal,
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      return await response.json();
    } catch (error) {
      if (error && error.name === 'AbortError') {
        throw new Error(`Timed out connecting to ${url}.`);
      }

      if (error instanceof TypeError) {
        throw new Error(`Could not connect to ${url}.`);
      }

      throw error;
    } finally {
      window.clearTimeout(timeoutId);
    }
  }

  async function refreshAiModels(showStatus = true) {
    const provider = getAiProvider();
    const endpoint = getAiEndpoint();

    if (!endpoint) {
      setAiStatus('Enter a provider endpoint before refreshing models.', 'error');
      return;
    }

    if (showStatus) {
      setAiStatus('Checking local provider for available models...', 'warning');
    }

    try {
      if (provider === 'promptforge') {
        await fetchJsonWithTimeout(`${endpoint}/api/status`);
        populateModelPresetOptions(promptForgeLaunchModels);
        populateAiModelOptions(promptForgeLaunchModels);
        aiModelMeta.textContent = 'PromptForge is reachable. Launch targets are listed; image review is not supported by its current API.';
        if (!aiModelInput.value.trim()) {
          aiModelInput.value = promptForgeLaunchModels[0]?.value || 'qwen';
        }
        syncInputToModelPreset();
        if (showStatus) {
          setAiStatus('PromptForge is reachable. It can launch its local text LLM, but image review still needs a dedicated endpoint.', 'warning');
        }
        return;
      }

      const payload = await fetchJsonWithTimeout(`${endpoint}/api/tags`);
      const discoveredModels = Array.isArray(payload.models)
        ? payload.models
            .map((model) => ({
              label: model.name || model.model || '',
              value: model.name || model.model || '',
            }))
            .filter((model) => model.value)
        : [];
      discoveredOllamaModels = discoveredModels.map((model) => model.value);
      const visionCapableModels = discoveredOllamaModels.filter((name) => isLikelyVisionModelName(name));
      const discoveredSummary = summarizeModelNames(discoveredOllamaModels);

      const mergedModels = mergeUniqueModelEntries(ollamaModelPresets, discoveredModels);
      populateModelPresetOptions(mergedModels);
      populateAiModelOptions(mergedModels);
      if (!discoveredOllamaModels.length) {
        aiModelMeta.textContent = 'Ollama responded, but did not report installed models.';
      } else if (!visionCapableModels.length) {
        aiModelMeta.textContent =
          `${discoveredOllamaModels.length} Ollama model${discoveredOllamaModels.length === 1 ? '' : 's'} found` +
          ` (${discoveredSummary}). None look vision-capable. Install one like gemma4:e4b or qwen2.5vl:7b.`;
      } else {
        aiModelMeta.textContent =
          `${discoveredOllamaModels.length} Ollama model${discoveredOllamaModels.length === 1 ? '' : 's'} found` +
          ` (${discoveredSummary}). ${visionCapableModels.length} look vision-capable.`;
      }

      if (!aiModelInput.value.trim()) {
        aiModelInput.value = mergedModels[0]?.value || '';
      }
      syncInputToModelPreset();

      if (showStatus) {
        if (!discoveredOllamaModels.length) {
          setAiStatus('Ollama is reachable, but no models were returned by /api/tags.', 'warning');
        } else {
          const selectedModel = aiModelInput.value.trim();
          const selectedInstalled = selectedModel
            ? isInstalledModelName(selectedModel, discoveredOllamaModels)
            : false;
          const selectedVision = selectedModel ? isLikelyVisionModelName(selectedModel) : false;
          const installedSummary = summarizeModelNames(discoveredOllamaModels);

          if (selectedModel && !selectedInstalled) {
            setAiStatus(
              `Ollama is reachable. Installed: ${installedSummary}. Selected model "${selectedModel}" is not installed. Run \`ollama pull ${selectedModel}\`, then click Refresh Models.`,
              'warning',
            );
          } else if (selectedModel && !selectedVision) {
            setAiStatus(
              `Ollama is reachable. "${selectedModel}" is installed but does not look vision-capable for image scan. Choose a vision model like gemma4:e4b or qwen2.5vl:7b.`,
              'warning',
            );
          } else {
            setAiStatus(
              `Ollama is reachable. Installed: ${installedSummary}. Select an image, then run review.`,
              'success',
            );
          }
        }
      }
    } catch (error) {
      discoveredOllamaModels = [];
      aiModelMeta.textContent =
        provider === 'ollama'
          ? 'No Ollama server responded. Start Ollama locally, then refresh models.'
          : 'PromptForge did not respond at this endpoint.';
      if (showStatus) {
        if (provider === 'ollama') {
          setAiStatus(
            `Could not reach Ollama at ${endpoint}. Run \`ollama serve\` in your terminal, then click Refresh Models.`,
            'error',
          );
        } else {
          setAiStatus(
            error instanceof Error
              ? `${error.message} Check the endpoint and start the local provider.`
              : 'Could not reach the local provider.',
            'error',
          );
        }
      }
    }
  }

  async function startAiProvider() {
    const provider = getAiProvider();
    const endpoint = getAiEndpoint();

    if (provider === 'ollama') {
      setAiStatus('This browser page cannot start Ollama. Start Ollama locally, then use Refresh Models here.', 'warning');
      return;
    }

    if (!endpoint) {
      setAiStatus('Enter the PromptForge endpoint before launching its local LLM.', 'error');
      return;
    }

    const modelType = aiModelInput.value.trim() || promptForgeLaunchModels[0]?.value || 'qwen';
    aiStartButton.disabled = true;
    setAiStatus('Asking PromptForge to launch its local LLM...', 'warning');

    try {
      await fetchJsonWithTimeout(
        `${endpoint}/api/launch-ai`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ model_type: modelType }),
        },
        aiHealthTimeoutMs,
      );
      setAiStatus('PromptForge launch requested. This starts its text LLM; image review still requires an image-review provider.', 'warning');
    } catch (error) {
      setAiStatus(
        error instanceof Error
          ? `${error.message} PromptForge must be running before this page can ask it to launch a model.`
          : 'PromptForge launch failed.',
        'error',
      );
    } finally {
      aiStartButton.disabled = false;
    }
  }

  function isLocalAiAllowed() {
    const host = window.location.hostname;
    const params = new URLSearchParams(window.location.search);
    return (
      window.location.protocol === 'file:' ||
      host === 'localhost' ||
      host === '127.0.0.1' ||
      host === '::1' ||
      params.get('localAi') === '1' ||
      window.localStorage.getItem('entryLocalAi') === '1'
    );
  }

  function updateAiAvailability() {
    const allowed = isLocalAiAllowed();
    aiReviewPanel.classList.toggle('opacity-70', !allowed);
    aiReviewControls.classList.toggle('hidden', !allowed);
    aiReviewLocalWarning.classList.toggle('hidden', allowed);
  }

  function sanitizeSubfolder(value) {
    return value
      .split(/[\\/]+/)
      .map((segment) => slugify(segment))
      .filter(Boolean);
  }

  function inferExtensionFromType(type) {
    const fallbackMap = {
      'image/jpeg': 'jpg',
      'image/png': 'png',
      'image/webp': 'webp',
      'image/avif': 'avif',
      'image/gif': 'gif',
      'image/tiff': 'tif',
      'image/svg+xml': 'svg',
    };

    return fallbackMap[type] || '';
  }

  function getFileExtension(file) {
    if (!file) {
      return '';
    }

    const pieces = file.name.split('.');
    if (pieces.length > 1) {
      return pieces.at(-1).toLowerCase();
    }

    return inferExtensionFromType(file.type);
  }

  function getResolvedImageSlug() {
    const typedSlug = slugInput.value.trim();
    if (typedSlug) {
      return slugify(typedSlug);
    }

    return slugify(titleInput.value.trim());
  }

  function getResolvedProductSlug() {
    const typedSlug = productSlugInput.value.trim();
    if (typedSlug) {
      return slugify(typedSlug);
    }

    const imageSlug = getResolvedImageSlug();
    return imageSlug ? `${imageSlug}-print` : '';
  }

  function buildImportedImageSrc(slug, subfolderSegments, extension) {
    const prefix = subfolderSegments.length ? `${subfolderSegments.join('/')}/` : '';
    return `/images/${prefix}${extension ? `${slug}.${extension}` : slug}`;
  }

  function updateImportPathPreview() {
    const workingMode = getActiveMode();
    const imageSlug = getResolvedImageSlug();
    const extension = getFileExtension(selectedImageFile);
    const segments = sanitizeSubfolder(subfolderInput.value.trim());

    if (!selectedImageFile) {
      if (workingMode === 'edit-gallery' && selectedImageRecord?.imageSrc) {
        importPathPreview.textContent = `Current image path: ${selectedImageRecord.imageSrc}`;
      } else {
        importPathPreview.textContent = 'Choose a local image file to preview the imported path.';
      }
      return;
    }

    if (!imageSlug) {
      importPathPreview.textContent = 'Enter a title or slug to generate the imported filename.';
      return;
    }

    importPathPreview.textContent = buildImportedImageSrc(imageSlug, segments, extension);
  }

  function updateSupportMessage() {
    if (fsApiSupported) {
      supportMessage.innerHTML =
        'Local writes are available in this browser. Choose a local image and the repo root, then submit to update the gallery data.';
      if (currentMode === 'edit-gallery') {
        supportMessage.innerHTML = 'Replacement imports are optional. Pick a local file to replace the selected image file.';
      }
      return;
    }

    supportMessage.innerHTML =
      'Local writes are not available in this browser. You can still fill the form and generate snippets, but you must move the file into <code>public/images</code> and update data files manually.';
  }

  function updateFolderMeta() {
    if (!selectedProjectDirectory) {
      folderMeta.textContent = 'No project folder selected yet.';
      return;
    }

    folderMeta.textContent = `Selected project: ${selectedProjectDirectory.name}.`;
  }

  function updateFileMeta() {
    const workingMode = getActiveMode();
    if (!selectedImageFile) {
      fileMeta.textContent =
        workingMode === 'edit-gallery'
          ? 'No replacement file selected yet. AI can still review from selected image path.'
          : 'No image file selected yet.';
      previewWrap.classList.add('hidden');
      previewImage.removeAttribute('src');
      return;
    }

    const sizeInMb = (selectedImageFile.size / (1024 * 1024)).toFixed(2);
    fileMeta.textContent = `${selectedImageFile.name} · ${sizeInMb} MB`;
    previewWrap.classList.remove('hidden');
  }

  function updatePreviewImage() {
    if (selectedPreviewUrl) {
      URL.revokeObjectURL(selectedPreviewUrl);
      selectedPreviewUrl = '';
    }

    if (!selectedImageFile) {
      if (currentMode === 'edit-gallery' && selectedImageRecord?.imageSrc) {
        previewImage.src = selectedImageRecord.imageSrc;
        previewWrap.classList.remove('hidden');
        return;
      }

      previewWrap.classList.add('hidden');
      previewImage.removeAttribute('src');
      return;
    }

    selectedPreviewUrl = URL.createObjectURL(selectedImageFile);
    previewImage.src = selectedPreviewUrl;
  }

  function syncDefaults() {
    const generatedSlug = slugify(titleInput.value.trim());

    if (!slugInput.dataset.dirty && generatedSlug) {
      slugInput.value = generatedSlug;
    }

    if (!productTitleInput.dataset.dirty && titleInput.value.trim()) {
      productTitleInput.value = titleInput.value.trim();
    }

    if (!productSlugInput.dataset.dirty && generatedSlug) {
      productSlugInput.value = `${generatedSlug}-print`;
    }
  }

  function updateProductFieldsState() {
    const enabled = getEffectiveCreateProductState();
    if (enabled && currentMode === 'edit-gallery' && (selectedProductRecord || selectedOriginalProductSlug)) {
      createProductCheckbox.checked = true;
    }
    productFieldset.disabled = !enabled;
    productFieldset.classList.toggle('opacity-60', !enabled);

    if (enabled) {
      printAvailableCheckbox.checked = true;
    }
  }

  function buildDirectEntries(imageSlug, formData) {
    const entries = [];

    for (const platformField of routePlatformFields) {
      const url = String(formData.get(platformField.field) || '').trim();
      if (!url) {
        continue;
      }

      entries.push({
        key: buildDirectKey(imageSlug, platformField.suffix),
        label: platformField.label,
        platform: platformField.platform,
        url,
      });
    }

    const otherLabel = String(formData.get('otherLabel') || '').trim();
    const otherUrl = String(formData.get('otherUrl') || '').trim();
    if (otherLabel && otherUrl) {
      entries.push({
        key: buildDirectKey(imageSlug, 'Other'),
        label: otherLabel,
        platform: 'other',
        url: otherUrl,
      });
    }

    return entries;
  }

  function buildExternalLinksSnippet(entries) {
    if (!entries.length) {
      return '// No outbound links entered yet.';
    }

    return entries
      .map((entry) => buildExternalLinkSnippet(entry))
      .join('\n\n');
  }

  function collectProductFormats(formData) {
    const presetFormats = Array.from(formData.getAll('productFormatPreset')).map((value) =>
      String(value).trim(),
    );
    const customFormats = splitList(String(formData.get('productCustomSizes') || ''));
    return uniqueList([...presetFormats, ...customFormats]);
  }

  function buildProductSnippet(formData, imageSlug, routeKeys) {
    const createProduct = getEffectiveCreateProductState();
    if (!createProduct) {
      return '// Product entry not enabled.';
    }

    const productTitle = String(formData.get('productTitle') || '').trim();
    const productSlug = getResolvedProductSlug();
    const productDescription = String(formData.get('productDescription') || '').trim();
    const productFormats = collectProductFormats(formData);
    const inquiryAllowed = Boolean(formData.get('productInquiryAllowed'));

    const lines = ['{'];
    pushString(lines, 'slug', productSlug);
    pushString(lines, 'imageSlug', imageSlug);
    pushString(lines, 'title', productTitle || String(formData.get('imageTitle') || '').trim());
    pushString(lines, 'shortDescription', productDescription);
    lines.push(arrayLine('availableFormats', productFormats));
    lines.push(arrayLine('routeKeys', routeKeys));
    pushBoolean(lines, 'inquiryAllowed', inquiryAllowed);
    lines.push('},');
    return lines.join('\n');
  }

  function buildImageSnippet(formData, imageSlug, productSlugValue, routeKeys) {
    const title = String(formData.get('imageTitle') || '').trim();
    const category = String(formData.get('imageCategory') || 'portrait').trim();
    const imageSrc = String(formData.get('imageSrc') || '').trim();
    const tags = splitList(String(formData.get('imageTags') || ''));
    const alt = String(formData.get('imageAlt') || '').trim();
    const hook = String(formData.get('imageHook') || '').trim();
    const story = String(formData.get('imageStory') || '').trim();
    const orientation = String(formData.get('imageOrientation') || '').trim();
    const year = String(formData.get('imageYear') || '').trim();
    const location = String(formData.get('imageLocation') || '').trim();
    const medium = String(formData.get('imageMedium') || '').trim();
    const bestFormat = String(formData.get('imageBestFormat') || '').trim();
    const createProduct = getEffectiveCreateProductState();
    const featured = Boolean(formData.get('imageFeatured'));
    const printAvailable = Boolean(formData.get('imagePrintAvailable')) || createProduct;
    const serviceCta = String(formData.get('imageServiceCta') || '').trim();

    const lines = ['{'];
    pushString(lines, 'slug', imageSlug);
    pushString(lines, 'title', title);
    pushString(lines, 'category', category);
    lines.push(arrayLine('tags', tags));
    pushString(lines, 'imageSrc', imageSrc);
    pushString(lines, 'alt', alt);
    pushString(lines, 'hook', hook);
    pushString(lines, 'story', story);
    pushString(lines, 'orientation', orientation);
    pushString(lines, 'year', year);
    pushString(lines, 'location', location);
    pushString(lines, 'medium', medium);
    pushString(lines, 'bestFormat', bestFormat);
    pushBoolean(lines, 'featured', featured);
    pushBoolean(lines, 'printAvailable', printAvailable);
    pushString(lines, 'serviceCTA', serviceCta);
    if (createProduct) {
      pushString(lines, 'productSlug', productSlugValue);
    }
    if (!routeKeys.length) {
      lines.push("  // Add productSlug and outbound links when this image is ready to sell.");
    }
    lines.push('},');
    return lines.join('\n');
  }

  function getCurrentModeRouteKeys(formData, imageSlug) {
    const directEntries = buildDirectEntries(imageSlug, formData);
    const directKeys = directEntries.map((entry) => entry.key);
    const sharedKeys = getSharedRouteKeysFromForm();
    return uniqueList([...sharedKeys, ...directKeys]);
  }

  function updateOutputs() {
    syncDefaults();
    updateProductFieldsState();
    updateImportPathPreview();

    const formData = new FormData(form);
    const imageSlug = getResolvedImageSlug();
    const productSlugValue = getResolvedProductSlug();
    const directEntries = buildDirectEntries(imageSlug, formData);
    const routeKeys = getCurrentModeRouteKeys(formData, imageSlug);

    externalLinksOutput.value = buildExternalLinksSnippet(directEntries);
    productOutput.value = buildProductSnippet(formData, imageSlug, routeKeys);
    imageOutput.value = buildImageSnippet(formData, imageSlug, productSlugValue, routeKeys);
  }

  function getCurrentFieldValues() {
    const formData = new FormData(form);
    return {
      title: String(formData.get('imageTitle') || '').trim(),
      category: String(formData.get('imageCategory') || '').trim(),
      tags: splitList(String(formData.get('imageTags') || '')),
      alt: String(formData.get('imageAlt') || '').trim(),
      hook: String(formData.get('imageHook') || '').trim(),
      story: String(formData.get('imageStory') || '').trim(),
      orientation: String(formData.get('imageOrientation') || '').trim(),
      medium: String(formData.get('imageMedium') || '').trim(),
      bestFormat: String(formData.get('imageBestFormat') || '').trim(),
      serviceCTA: String(formData.get('imageServiceCta') || '').trim(),
      productShortDescription: String(formData.get('productDescription') || '').trim(),
      productFormats: collectProductFormats(formData),
    };
  }

  function replacePromptVariables(template, variables) {
    return Object.entries(variables).reduce((result, [key, value]) => {
      return result.replaceAll(`{{${key}}}`, value);
    }, template);
  }

  function getSelectedImageDimensions() {
    if (previewImage.naturalWidth && previewImage.naturalHeight) {
      return `${previewImage.naturalWidth} x ${previewImage.naturalHeight}`;
    }

    return 'Unknown';
  }

  function buildAiPrompt() {
    const fileContext = {
      fileName: selectedImageFile?.name || '',
      fileType: selectedImageFile?.type || '',
      fileSizeMb: selectedImageFile ? (selectedImageFile.size / (1024 * 1024)).toFixed(2) : '',
      visibleDimensions: getSelectedImageDimensions(),
      publicPath: imageSrcInput.value.trim(),
      reviewInput: latestAiReviewInputContext,
    };

    return replacePromptVariables(aiPromptConfig.template || '', {
      imageCategories: imageCategories.join(', '),
      orientations: orientations.join(', '),
      serviceCtas: serviceCtas.join(', '),
      currentValues: JSON.stringify(getCurrentFieldValues(), null, 2),
      fileContext: JSON.stringify(fileContext, null, 2),
    });
  }

  function readFileAsBase64(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.addEventListener('load', () => {
        const value = String(reader.result || '');
        resolve(value.includes(',') ? value.split(',').at(-1) : value);
      });
      reader.addEventListener('error', () => reject(new Error('The selected image could not be read.')));
      reader.readAsDataURL(file);
    });
  }

  function canvasToBlob(canvas, type, quality) {
    return new Promise((resolve, reject) => {
      canvas.toBlob(
        (blob) => {
          if (blob) {
            resolve(blob);
          } else {
            reject(new Error('The review image could not be prepared.'));
          }
        },
        type,
        quality,
      );
    });
  }

  async function readImageForAiReview(file) {
    if (!file.type.startsWith('image/') || file.type === 'image/svg+xml' || !('createImageBitmap' in window)) {
      return {
        base64: await readFileAsBase64(file),
        context: 'Original selected file.',
      };
    }

    let bitmap = null;
    try {
      bitmap = await createImageBitmap(file);
      const longestSide = Math.max(bitmap.width, bitmap.height);
      const scale = Math.min(1, aiReviewMaxDimension / longestSide);
      const shouldResize = scale < 1 || file.size > 4 * 1024 * 1024;

      if (!shouldResize) {
        return {
          base64: await readFileAsBase64(file),
          context: `Original selected file (${bitmap.width} x ${bitmap.height}).`,
        };
      }

      const width = Math.max(1, Math.round(bitmap.width * scale));
      const height = Math.max(1, Math.round(bitmap.height * scale));
      const canvas = document.createElement('canvas');
      canvas.width = width;
      canvas.height = height;
      const context = canvas.getContext('2d');
      if (!context) {
        throw new Error('The review image could not be prepared.');
      }

      context.drawImage(bitmap, 0, 0, width, height);
      const reviewBlob = await canvasToBlob(canvas, 'image/jpeg', aiReviewJpegQuality);
      return {
        base64: await readFileAsBase64(reviewBlob),
        context: `Downscaled review copy (${width} x ${height}, JPEG quality ${aiReviewJpegQuality}). Original file is kept for import.`,
      };
    } catch (error) {
      return {
        base64: await readFileAsBase64(file),
        context: 'Original selected file. Downscaling was not available.',
      };
    } finally {
      if (bitmap && typeof bitmap.close === 'function') {
        bitmap.close();
      }
    }
  }

  async function fetchReviewImageFromUrl(imageUrl, fallbackName) {
    const response = await fetch(imageUrl);
    if (!response.ok) {
      throw new Error(`Could not load ${imageUrl} for AI review.`);
    }

    const blob = await response.blob();
    const normalizedName = (fallbackName || 'image').replace(/[^a-z0-9.-]+/gi, '-');
    const extensionFromUrl = imageUrl.split('?')[0].split('#')[0].match(/\.([a-z0-9]+)$/i)?.[1];
    const extension = extensionFromUrl || inferExtensionFromType(blob.type);
    const fileName = extension ? `${normalizedName}.${extension}` : normalizedName;

    return new File([blob], fileName, { type: blob.type || 'image/jpeg' });
  }

  async function resolveReviewFile() {
    if (selectedImageFile) {
      return selectedImageFile;
    }

    if (currentMode !== 'edit-gallery') {
      return null;
    }

    const imageRecord = getCurrentImageRecord();
    const imagePath = String(imageRecord?.imageSrc || imageSrcInput.value || '').trim();
    if (!imagePath) {
      return null;
    }

    return fetchReviewImageFromUrl(imagePath, imageRecord?.slug || getResolvedImageSlug() || 'image');
  }

  function parseAiReviewResponse(value) {
    if (!value) {
      throw new Error('The AI review did not return any content.');
    }

    if (typeof value === 'object') {
      return value;
    }

    const text = String(value).trim();
    try {
      return JSON.parse(text);
    } catch (error) {
      const match = text.match(/\{[\s\S]*\}/);
      if (match) {
        return JSON.parse(match[0]);
      }

      throw new Error('The AI review returned text that was not valid JSON.');
    }
  }

  function normalizeAiReview(review) {
    const normalized = {
      title: String(review.title || '').trim(),
      category: imageCategories.includes(review.category) ? review.category : '',
      tags: uniqueList(Array.isArray(review.tags) ? review.tags.map((tag) => slugify(String(tag))) : []),
      alt: String(review.alt || '').trim(),
      hook: String(review.hook || '').trim(),
      story: String(review.story || '').trim(),
      orientation: orientations.includes(review.orientation) ? review.orientation : '',
      medium: String(review.medium || '').trim(),
      bestFormat: String(review.bestFormat || '').trim(),
      serviceCTA: serviceCtas.includes(review.serviceCTA) ? review.serviceCTA : '',
      productShortDescription: String(review.productShortDescription || '').trim(),
      productFormats: uniqueList(Array.isArray(review.productFormats) ? review.productFormats.map((item) => String(item).trim()) : []),
      cautions: Array.isArray(review.cautions)
        ? review.cautions.map((item) => String(item).trim()).filter(Boolean)
        : [],
    };

    if (review.category && !normalized.category) {
      normalized.cautions.push(`Ignored unsupported category: ${review.category}`);
    }

    if (review.orientation && !normalized.orientation) {
      normalized.cautions.push(`Ignored unsupported orientation: ${review.orientation}`);
    }

    if (review.serviceCTA && !normalized.serviceCTA) {
      normalized.cautions.push(`Ignored unsupported service CTA: ${review.serviceCTA}`);
    }

    return normalized;
  }

  function getAiSuggestionDisplayValue(field, value) {
    if (Array.isArray(value)) {
      return value.join(', ');
    }

    return String(value || '').trim();
  }

  function renderAiSuggestions(review) {
    aiSuggestionsList.innerHTML = '';
    const entries = aiSuggestionFields
      .map((field) => ({
        ...field,
        value: getAiSuggestionDisplayValue(field, review[field.key]),
      }))
      .filter((entry) => entry.value);

    for (const entry of entries) {
      const label = document.createElement('label');
      label.className = 'grid cursor-pointer gap-3 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-paper sm:grid-cols-[auto_0.28fr_1fr]';

      const checkbox = document.createElement('input');
      checkbox.className = 'mt-1 h-4 w-4';
      checkbox.type = 'checkbox';
      checkbox.checked = entry.defaultChecked !== false;
      checkbox.dataset.aiField = entry.key;

      const name = document.createElement('span');
      name.className = 'font-semibold';
      name.textContent = entry.label;

      const value = document.createElement('span');
      value.className = 'text-steel';
      value.textContent = entry.value;

      label.append(checkbox, name, value);
      aiSuggestionsList.append(label);
    }

    if (!entries.length) {
      const empty = document.createElement('p');
      empty.className = 'copy-muted';
      empty.textContent = 'No usable suggestions were found in the review JSON.';
      aiSuggestionsList.append(empty);
    }

    aiCautions.classList.toggle('hidden', !review.cautions.length);
    aiCautions.textContent = review.cautions.length ? `Verify: ${review.cautions.join(' ')}` : '';
    aiSuggestionsWrap.classList.remove('hidden');
    aiSuggestionsWrap.dataset.review = JSON.stringify(review);
  }

  function setInputValue(targetId, value) {
    const target = document.getElementById(targetId);
    if (!target) {
      return;
    }

    target.value = value;
    target.dispatchEvent(new Event('input', { bubbles: true }));
    target.dispatchEvent(new Event('change', { bubbles: true }));
  }

  function setRadioValue(name, value) {
    const target = form.querySelector(`input[name="${name}"][value="${value}"]`);
    if (target) {
      target.checked = true;
      target.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }

  function applyAiSuggestions() {
    const review = JSON.parse(aiSuggestionsWrap.dataset.review || '{}');
    const checkedFields = Array.from(aiSuggestionsList.querySelectorAll('input[data-ai-field]:checked')).map(
      (input) => input.dataset.aiField,
    );

    for (const field of aiSuggestionFields) {
      if (!checkedFields.includes(field.key)) {
        continue;
      }

      const value = getAiSuggestionDisplayValue(field, review[field.key]);
      if (!value) {
        continue;
      }

      if (field.type === 'radio') {
        setRadioValue(field.targetName, value);
      } else if (field.type === 'productText' || field.type === 'productList') {
        createProductCheckbox.checked = true;
        updateProductFieldsState();
        setInputValue(field.targetId, value);
      } else {
        setInputValue(field.targetId, value);
      }
    }

    updateOutputs();
    imageEntrySection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setAiStatus('Checked AI suggestions were applied to the Image section. Review before submitting or copying snippets.', 'success');
  }

  async function runAiReview() {
    clearAiStatus();

    const reviewSourceFile = await resolveReviewFile();
    if (!reviewSourceFile) {
      setAiStatus(
        currentMode === 'edit-gallery'
          ? 'Choose a local image file to replace this entry, or ensure this image has a valid public path before running AI review.'
          : 'Choose a local image file before running AI review.',
        'error',
      );
      return;
    }

    const provider = getAiProvider();
    if (provider === 'promptforge') {
      setAiStatus(
        'PromptForge is wired here as a launcher only. Its current API does not accept image review requests. Choose Ollama with an installed vision model, or paste JSON manually.',
        'error',
      );
      return;
    }

    const endpoint = getAiEndpoint();
    const model = aiModelInput.value.trim();
    if (!endpoint || !model) {
      setAiStatus('Enter an Ollama endpoint and choose an installed vision-capable model before running review.', 'error');
      return;
    }
    if (discoveredOllamaModels.length && !isInstalledModelName(model, discoveredOllamaModels)) {
      const installedSummary = summarizeModelNames(discoveredOllamaModels);
      setAiStatus(
        `Selected model "${model}" is not installed. Installed: ${installedSummary}. Run \`ollama pull ${model}\`, then click Refresh Models.`,
        'error',
      );
      return;
    }
    if (!isLikelyVisionModelName(model)) {
      setAiStatus(
        `"${model}" does not look vision-capable for image scanning. Choose a vision model like gemma4:e4b or qwen2.5vl:7b.`,
        'error',
      );
      return;
    }

    const requestTimeoutMs = isLikelyVisionModelName(model) ? aiVisionRequestTimeoutMs : aiRequestTimeoutMs;
    const timeoutSeconds = Math.round(requestTimeoutMs / 1000);

    aiReviewButton.disabled = true;
    setAiStatus(`Reviewing image with ${model} (timeout ${timeoutSeconds}s)...`, 'warning');

    let requestTimeoutId = null;
    try {
      const reviewImage = await readImageForAiReview(reviewSourceFile);
      latestAiReviewInputContext = reviewImage.context;
      const { controller, timeoutId } = timeoutSignal(requestTimeoutMs);
      requestTimeoutId = timeoutId;
      const response = await fetch(`${endpoint}/api/generate`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        signal: controller.signal,
        body: JSON.stringify({
          model,
          prompt: buildAiPrompt(),
          images: [reviewImage.base64],
          stream: false,
          keep_alive: '20m',
          format: aiReviewSchema,
          options: {
            temperature: 0.2,
          },
        }),
      });
      window.clearTimeout(requestTimeoutId);
      requestTimeoutId = null;

      if (!response.ok) {
        throw new Error(`Local model request failed with HTTP ${response.status}.`);
      }

      const payload = await response.json();
      const review = normalizeAiReview(parseAiReviewResponse(payload.response || payload));
      renderAiSuggestions(review);
      aiJsonInput.value = JSON.stringify(review, null, 2);
      setAiStatus('AI suggestions are ready. Check the fields you want to apply.', 'success');
    } catch (error) {
      setAiStatus(
        error && error.name === 'AbortError'
          ? `The local model did not respond within ${timeoutSeconds}s. Try a smaller image, use gemma4:e2b, or keep gemma4:e4b warm and retry. You can paste review JSON into the fallback box instead.`
          : error instanceof Error
          ? `${error.message} You can paste review JSON into the fallback box instead.`
          : 'AI review failed. You can paste review JSON into the fallback box instead.',
        'error',
      );
    } finally {
      if (requestTimeoutId) {
        window.clearTimeout(requestTimeoutId);
      }
      aiReviewButton.disabled = false;
    }
  }

  function parsePastedAiJson() {
    try {
      const review = normalizeAiReview(parseAiReviewResponse(aiJsonInput.value));
      renderAiSuggestions(review);
      setAiStatus('Pasted AI suggestions are ready. Check the fields you want to apply.', 'success');
    } catch (error) {
      setAiStatus(error instanceof Error ? error.message : 'The pasted JSON could not be parsed.', 'error');
    }
  }

  function copyOutput(targetId, button) {
    const target = document.getElementById(targetId);
    if (!(target instanceof HTMLTextAreaElement)) {
      return;
    }

    navigator.clipboard.writeText(target.value).then(() => {
      const previousText = button.textContent;
      button.textContent = 'Copied';
      window.setTimeout(() => {
        button.textContent = previousText;
      }, 1200);
    });
  }

  function downloadAll() {
    const content = [
      '// externalLinks.ts',
      externalLinksOutput.value,
      '',
      '// products.ts',
      productOutput.value,
      '',
      '// images.ts',
      imageOutput.value,
      '',
    ].join('\n');

    const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = 'content-entry-snippets.txt';
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  async function ensureDirectoryPermission(handle) {
    const permissionOptions = { mode: 'readwrite' };

    if (typeof handle.queryPermission === 'function') {
      const currentPermission = await handle.queryPermission(permissionOptions);
      if (currentPermission === 'granted') {
        return true;
      }
    }

    if (typeof handle.requestPermission === 'function') {
      const requestedPermission = await handle.requestPermission(permissionOptions);
      return requestedPermission === 'granted';
    }

    return true;
  }

  async function resolveTargetDirectory(rootHandle, segments) {
    let currentHandle = rootHandle;

    for (const segment of segments) {
      currentHandle = await currentHandle.getDirectoryHandle(segment, { create: true });
    }

    return currentHandle;
  }

  async function fileAlreadyExists(directoryHandle, fileName) {
    try {
      await directoryHandle.getFileHandle(fileName);
      return true;
    } catch (error) {
      if (error && error.name === 'NotFoundError') {
        return false;
      }

      throw error;
    }
  }

  async function looksLikeProjectRootDirectory(handle) {
    if (!handle) {
      return false;
    }

    try {
      await handle.getFileHandle('package.json');
      const publicHandle = await handle.getDirectoryHandle('public');
      const imagesHandle = await publicHandle.getDirectoryHandle('images');
      await imagesHandle.getDirectoryHandle('placeholders');
      const srcHandle = await handle.getDirectoryHandle('src');
      const dataHandle = await srcHandle.getDirectoryHandle('data');
      await dataHandle.getFileHandle('images.ts');
      await dataHandle.getFileHandle('products.ts');
      await dataHandle.getFileHandle('externalLinks.ts');
      return true;
    } catch (error) {
      if (error && error.name === 'NotFoundError') {
        return false;
      }

      throw error;
    }
  }

  async function getProjectImagesDirectory() {
    if (!selectedProjectDirectory) {
      throw new Error('Choose the repo root before submitting.');
    }

    const publicHandle = await selectedProjectDirectory.getDirectoryHandle('public');
    return publicHandle.getDirectoryHandle('images');
  }

  async function getDataFileHandle(fileName) {
    if (!selectedProjectDirectory) {
      throw new Error('Choose the repo root before submitting.');
    }

    const srcHandle = await selectedProjectDirectory.getDirectoryHandle('src');
    const dataHandle = await srcHandle.getDirectoryHandle('data');
    return dataHandle.getFileHandle(fileName);
  }

  async function readTextFile(fileHandle) {
    const file = await fileHandle.getFile();
    return file.text();
  }

  async function writeTextFile(fileHandle, content) {
    const writable = await fileHandle.createWritable();
    await writable.write(content);
    await writable.close();
  }

  function indentSnippet(snippet, spaces = 2) {
    const indent = ' '.repeat(spaces);
    return snippet
      .trim()
      .split('\n')
      .map((line) => `${indent}${line}`)
      .join('\n');
  }

  function findExportedArrayRange(source, exportName) {
    const declarationIndex = source.indexOf(`export const ${exportName}`);
    if (declarationIndex === -1) {
      throw new Error(`Could not find export const ${exportName} in the data file.`);
    }

    const arrayStart = source.indexOf('[', declarationIndex);
    const closeMatch = source.slice(arrayStart).match(/\r?\n\];/);
    const arrayEnd = closeMatch ? arrayStart + closeMatch.index : -1;
    if (arrayStart === -1 || arrayEnd === -1) {
      throw new Error(`Could not find the ${exportName} array closing bracket.`);
    }

    return { arrayStart, arrayEnd };
  }

  function findMatchingBrace(source, openIndex) {
    let depth = 0;
    let quote = '';
    let escaped = false;
    let lineComment = false;
    let blockComment = false;

    for (let index = openIndex; index < source.length; index += 1) {
      const char = source[index];
      const nextChar = source[index + 1];

      if (lineComment) {
        if (char === '\n') {
          lineComment = false;
        }
        continue;
      }

      if (blockComment) {
        if (char === '*' && nextChar === '/') {
          blockComment = false;
          index += 1;
        }
        continue;
      }

      if (quote) {
        if (escaped) {
          escaped = false;
        } else if (char === '\\') {
          escaped = true;
        } else if (char === quote) {
          quote = '';
        }
        continue;
      }

      if (char === '/' && nextChar === '/') {
        lineComment = true;
        index += 1;
        continue;
      }

      if (char === '/' && nextChar === '*') {
        blockComment = true;
        index += 1;
        continue;
      }

      if (char === '\'' || char === '"' || char === '`') {
        quote = char;
        continue;
      }

      if (char === '{') {
        depth += 1;
      } else if (char === '}') {
        depth -= 1;
        if (depth === 0) {
          return index;
        }
      }
    }

    return -1;
  }

  function getLineStart(source, index) {
    return source.lastIndexOf('\n', index) + 1;
  }

  function includeTrailingComma(source, index) {
    let endIndex = index + 1;
    while (source[endIndex] === ' ' || source[endIndex] === '\t') {
      endIndex += 1;
    }
    if (source[endIndex] === ',') {
      endIndex += 1;
    }
    return endIndex;
  }

  function objectHasStringProperty(block, propertyName, propertyValue) {
    const pattern = new RegExp(`\\b${propertyName}\\s*:\\s*['"]${escapeRegExp(propertyValue)}['"]`);
    return pattern.test(block);
  }

  function findObjectRangeByStringProperty(source, exportName, propertyName, propertyValue) {
    if (!propertyValue) {
      return null;
    }

    const { arrayStart, arrayEnd } = findExportedArrayRange(source, exportName);
    let searchIndex = arrayStart + 1;

    while (searchIndex < arrayEnd) {
      const objectStart = source.indexOf('{', searchIndex);
      if (objectStart === -1 || objectStart >= arrayEnd) {
        return null;
      }

      const objectEnd = findMatchingBrace(source, objectStart);
      if (objectEnd === -1 || objectEnd > arrayEnd) {
        throw new Error(`Could not parse an object inside ${exportName}.`);
      }

      const objectSource = source.slice(objectStart, objectEnd + 1);
      if (objectHasStringProperty(objectSource, propertyName, propertyValue)) {
        return {
          start: getLineStart(source, objectStart),
          end: includeTrailingComma(source, objectEnd),
        };
      }

      searchIndex = objectEnd + 1;
    }

    return null;
  }

  function appendToExportedArray(source, exportName, entrySnippet, duplicateNeedle) {
    if (duplicateNeedle && source.includes(duplicateNeedle)) {
      throw new Error(`A ${exportName} entry already exists for this slug or key.`);
    }

    const { arrayEnd } = findExportedArrayRange(source, exportName);
    return `${source.slice(0, arrayEnd)}\n${indentSnippet(entrySnippet)}${source.slice(arrayEnd)}`;
  }

  function replaceInExportedArray(source, exportName, originalProperty, originalValue, entrySnippet) {
    const range = findObjectRangeByStringProperty(source, exportName, originalProperty, originalValue);
    if (!range) {
      throw new Error(`Could not find the existing ${exportName} entry for ${originalValue}.`);
    }

    return `${source.slice(0, range.start)}${indentSnippet(entrySnippet)}${source.slice(range.end)}`;
  }

  function assertNoConflictingArrayEntry(source, exportName, propertyName, nextValue, originalValue) {
    if (!nextValue || nextValue === originalValue) {
      return;
    }

    const existingRange = findObjectRangeByStringProperty(source, exportName, propertyName, nextValue);
    if (existingRange) {
      throw new Error(`A ${exportName} entry already exists for ${nextValue}. Choose a different slug.`);
    }
  }

  function buildExternalLinkSnippet(entry) {
    return `${entry.key}: {\n  key: ${quoted(entry.key)},\n  label: ${quoted(entry.label)},\n  url: ${quoted(entry.url)},\n  platform: ${quoted(entry.platform)},\n},`;
  }

  function findExternalLinksRecordRange(source) {
    const declarationIndex = source.indexOf('export const externalLinks');
    if (declarationIndex === -1) {
      throw new Error('Could not find export const externalLinks in the data file.');
    }

    const recordStart = source.indexOf('{', declarationIndex);
    const closeMatches = Array.from(source.matchAll(/\r?\n\};/g));
    const lastCloseMatch = closeMatches.at(-1);
    const recordEnd = lastCloseMatch ? lastCloseMatch.index : -1;
    if (recordStart === -1 || recordEnd === -1 || recordEnd <= recordStart) {
      throw new Error('Could not find the externalLinks record closing brace.');
    }

    return { recordStart, recordEnd };
  }

  function findExternalLinkEntryRange(source, key) {
    const { recordStart, recordEnd } = findExternalLinksRecordRange(source);
    const recordSource = source.slice(recordStart, recordEnd);
    const pattern = new RegExp(`\\n\\s*${escapeRegExp(key)}\\s*:\\s*\\{`, 'g');
    const match = pattern.exec(recordSource);
    if (!match) {
      return null;
    }

    const entryStart = recordStart + match.index + 1;
    const objectStart = source.indexOf('{', entryStart);
    const objectEnd = findMatchingBrace(source, objectStart);
    if (objectStart === -1 || objectEnd === -1 || objectEnd > recordEnd) {
      throw new Error(`Could not parse the externalLinks entry for ${key}.`);
    }

    return {
      start: entryStart,
      end: includeTrailingComma(source, objectEnd),
    };
  }

  function upsertExternalLinksRecord(source, entries) {
    if (!entries.length) {
      return source;
    }

    return entries.reduce((nextSource, entry) => {
      const entrySnippet = buildExternalLinkSnippet(entry);
      const existingRange = findExternalLinkEntryRange(nextSource, entry.key);
      if (existingRange) {
        return `${nextSource.slice(0, existingRange.start)}${indentSnippet(entrySnippet)}${nextSource.slice(existingRange.end)}`;
      }

      const { recordEnd } = findExternalLinksRecordRange(nextSource);
      return `${nextSource.slice(0, recordEnd)}\n${indentSnippet(entrySnippet)}${nextSource.slice(recordEnd)}`;
    }, source);
  }

  async function importSelectedFile(imageSlug) {
    if (!selectedImageFile) {
      throw new Error('Choose a local image file before submitting.');
    }

    const hasPermission = await ensureDirectoryPermission(selectedProjectDirectory);
    if (!hasPermission) {
      throw new Error('Write permission was denied for the selected project folder.');
    }

    const extension = getFileExtension(selectedImageFile);
    const targetFileName = extension ? `${imageSlug}.${extension}` : imageSlug;
    const subfolderSegments = sanitizeSubfolder(subfolderInput.value.trim());
    const imagesDirectory = await getProjectImagesDirectory();
    const destinationDirectory = await resolveTargetDirectory(imagesDirectory, subfolderSegments);

    if (await fileAlreadyExists(destinationDirectory, targetFileName)) {
      const relativeFolder = subfolderSegments.length ? `/${subfolderSegments.join('/')}` : '';
      throw new Error(`A file named ${targetFileName} already exists in /images${relativeFolder}. Choose a different slug or subfolder.`);
    }

    const fileHandle = await destinationDirectory.getFileHandle(targetFileName, { create: true });
    const writable = await fileHandle.createWritable();
    await writable.write(await selectedImageFile.arrayBuffer());
    await writable.close();

    return {
      fileName: targetFileName,
      publicPath: buildImportedImageSrc(imageSlug, subfolderSegments, extension),
    };
  }

  async function writeEntryDataFiles(imageSlug, productSlugValue, externalEntries) {
    const hasPermission = await ensureDirectoryPermission(selectedProjectDirectory);
    if (!hasPermission) {
      throw new Error('Write permission was denied for the selected project folder.');
    }

    const isEditMode = currentMode === 'edit-gallery';
    const imagesHandle = await getDataFileHandle('images.ts');
    const imagesSource = await readTextFile(imagesHandle);

    let nextImagesSource = '';
    if (isEditMode) {
      if (!selectedOriginalImageSlug) {
        throw new Error('Choose an existing gallery image before updating.');
      }
      assertNoConflictingArrayEntry(imagesSource, 'images', 'slug', imageSlug, selectedOriginalImageSlug);
      nextImagesSource = replaceInExportedArray(
        imagesSource,
        'images',
        'slug',
        selectedOriginalImageSlug,
        imageOutput.value,
      );
    } else {
      assertNoConflictingArrayEntry(imagesSource, 'images', 'slug', imageSlug, '');
      nextImagesSource = appendToExportedArray(
        imagesSource,
        'images',
        imageOutput.value,
        `slug: '${imageSlug}'`,
      );
    }

    const writes = [{ handle: imagesHandle, content: nextImagesSource, path: 'src/data/images.ts' }];

    if (!productOutput.value.trim().startsWith('//')) {
      const productsHandle = await getDataFileHandle('products.ts');
      const productsSource = await readTextFile(productsHandle);
      const originalProductSlug = selectedOriginalProductSlug || selectedImageRecord?.productSlug || '';
      const hasOriginalProduct = Boolean(
        isEditMode &&
          originalProductSlug &&
          findObjectRangeByStringProperty(productsSource, 'products', 'slug', originalProductSlug),
      );
      let nextProductsSource = '';

      if (hasOriginalProduct) {
        assertNoConflictingArrayEntry(productsSource, 'products', 'slug', productSlugValue, originalProductSlug);
        nextProductsSource = replaceInExportedArray(
          productsSource,
          'products',
          'slug',
          originalProductSlug,
          productOutput.value,
        );
      } else {
        assertNoConflictingArrayEntry(productsSource, 'products', 'slug', productSlugValue, '');
        nextProductsSource = appendToExportedArray(
          productsSource,
          'products',
          productOutput.value,
          `slug: '${productSlugValue}'`,
        );
      }

      writes.push({ handle: productsHandle, content: nextProductsSource, path: 'src/data/products.ts' });
    }

    if (externalEntries.length) {
      const externalLinksHandle = await getDataFileHandle('externalLinks.ts');
      const externalLinksSource = await readTextFile(externalLinksHandle);
      const nextExternalLinksSource = upsertExternalLinksRecord(externalLinksSource, externalEntries);
      writes.push({ handle: externalLinksHandle, content: nextExternalLinksSource, path: 'src/data/externalLinks.ts' });
    }

    for (const write of writes) {
      await writeTextFile(write.handle, write.content);
    }

    return writes.map((write) => write.path);
  }

  async function handleChooseFolder() {
    clearStatus();

    if (!fsApiSupported) {
      setStatus(
        'Local file writes are not available in this browser. Use snippets as a manual fallback.',
        'warning',
      );
      return;
    }

    try {
      const directoryHandle = await window.showDirectoryPicker({ mode: 'readwrite' });
      const isProjectRootDirectory = await looksLikeProjectRootDirectory(directoryHandle);
      if (!isProjectRootDirectory) {
        selectedProjectDirectory = null;
        updateFolderMeta();
        setStatus(
          'Choose the repo root folder. This helper expects package.json, public/images, and src/data.',
          'warning',
        );
      } else {
        selectedProjectDirectory = directoryHandle;
        updateFolderMeta();
        setStatus(
          currentMode === 'edit-gallery'
            ? 'Project root selected. Submit will update local gallery data.'
            : 'Project root selected. Submit will add the image and update local gallery data.',
          'success',
        );
      }
    } catch (error) {
      if (error && error.name === 'AbortError') {
        return;
      }

      setStatus('The project folder could not be selected. Try again.', 'error');
    }
  }

  async function handleSubmit(event) {
    event.preventDefault();
    clearStatus();
    syncDefaults();
    updateProductFieldsState();

    const isEditMode = currentMode === 'edit-gallery';
    const imageTitle = titleInput.value.trim();
    const imageSlug = getResolvedImageSlug();

    if (isEditMode && !selectedOriginalImageSlug) {
      setStatus('Choose an existing gallery image before updating.', 'error', { reveal: true });
      editImageSelect?.focus({ preventScroll: true });
      return;
    }

    if (!imageTitle && !imageSlug) {
      setStatus('Enter a title or slug before submitting.', 'error', { reveal: true });
      titleInput.focus({ preventScroll: true });
      return;
    }

    if (imageSlug && slugInput.value.trim() !== imageSlug) {
      slugInput.value = imageSlug;
    }

    const createProduct = getEffectiveCreateProductState();
    if (createProduct && productSlugInput.value.trim() !== getResolvedProductSlug()) {
      productSlugInput.value = getResolvedProductSlug();
    }
    const productSlugValue = getResolvedProductSlug();

    let finalPublicPath = imageSrcInput.value.trim();

    try {
      let importResult = null;
      if (selectedImageFile) {
        if (!fsApiSupported) {
          setStatus(
            'Local writes are not available here. Move the file into public/images manually and enter the public path before submitting.',
            'error',
            { reveal: true },
          );
          return;
        }

        if (!selectedProjectDirectory) {
          setStatus(
            'Choose the repo root folder so submit can copy the image into public/images and update gallery data.',
            'error',
            { reveal: true },
          );
          return;
        }

        importResult = await importSelectedFile(imageSlug);
        finalPublicPath = importResult.publicPath;
        imageSrcInput.value = finalPublicPath;
      }

      if (!finalPublicPath) {
        if (fsApiSupported) {
          setStatus(
            'Choose an image file and the repo root, or enter the public image path manually before submitting.',
            'error',
            { reveal: true },
          );
          return;
        }

        setStatus(
          'Local writes are not available here. Move the file into public/images manually and enter the public path before submitting.',
          'error',
          { reveal: true },
        );
        return;
      }

      imageSrcInput.value = finalPublicPath;
      updateOutputs();

      const finalFormData = new FormData(form);
      const finalExternalEntries = buildDirectEntries(imageSlug, finalFormData);

      if (fsApiSupported && selectedProjectDirectory) {
        const writtenFiles = await writeEntryDataFiles(imageSlug, productSlugValue, finalExternalEntries);
        const importMessage = importResult
          ? `Imported ${importResult.fileName} to ${importResult.publicPath}. `
          : '';
        const actionMessage = isEditMode ? `Updated ${imageSlug}` : `Added ${imageSlug}`;
        setStatus(
          `${importMessage}${actionMessage} in local gallery data: ${writtenFiles.join(', ')}. Refresh /gallery/ to see it.`,
          'success',
          { reveal: true },
        );
        return;
      }

      setStatus(
        `Snippets refreshed using ${finalPublicPath}. Choose the repo root to write gallery data automatically.`,
        fsApiSupported ? 'warning' : 'success',
        { reveal: true },
      );
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'The file import failed.', 'error', { reveal: true });
    }
  }

  slugInput.addEventListener('input', () => {
    slugInput.dataset.dirty = slugInput.value.trim() ? 'true' : '';
    updateOutputs();
  });

  productTitleInput.addEventListener('input', () => {
    productTitleInput.dataset.dirty = productTitleInput.value.trim() ? 'true' : '';
    updateOutputs();
  });

  productSlugInput.addEventListener('input', () => {
    productSlugInput.dataset.dirty = productSlugInput.value.trim() ? 'true' : '';
    updateOutputs();
  });

  fileInput.addEventListener('change', () => {
    selectedImageFile = fileInput.files && fileInput.files.length ? fileInput.files[0] : null;
    updateFileMeta();
    updatePreviewImage();
    updateOutputs();
  });

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      refreshModeTabs(button.getAttribute('data-entry-tab'));
    });
  });

  if (editImageSelect) {
    editImageSelect.addEventListener('change', applyEditImageSelection);
  }

  folderButton.addEventListener('click', handleChooseFolder);
  aiProviderSelect.addEventListener('change', () => {
    applyAiProviderDefaults({ resetEndpoint: true, resetModel: true });
    clearAiStatus();
  });
  aiEndpointInput.addEventListener('change', () => {
    applyAiProviderDefaults();
  });
  aiModelPresetSelect.addEventListener('change', () => {
    syncModelPresetToInput();
    clearAiStatus();
  });
  aiModelInput.addEventListener('input', () => {
    syncInputToModelPreset();
  });
  aiStartButton.addEventListener('click', startAiProvider);
  aiRefreshModelsButton.addEventListener('click', () => refreshAiModels(true));
  aiReviewButton.addEventListener('click', runAiReview);
  aiParseJsonButton.addEventListener('click', parsePastedAiJson);
  aiApplyButton.addEventListener('click', applyAiSuggestions);
  createProductCheckbox.addEventListener('change', updateOutputs);
  titleInput.addEventListener('input', updateOutputs);
  form.addEventListener('input', updateOutputs);
  form.addEventListener('change', updateOutputs);
  form.addEventListener('submit', handleSubmit);

  copyButtons.forEach((button) => {
    button.addEventListener('click', () => {
      copyOutput(button.dataset.copyTarget, button);
    });
  });

  if (downloadButton) {
    downloadButton.addEventListener('click', downloadAll);
  }

  folderButton.disabled = !fsApiSupported;
  populateEditGallerySelect();
  refreshModeTabs('file-import', { announce: false });
  updateSupportMessage();
  updateAiAvailability();
  applyAiProviderDefaults();
  updateFolderMeta();
  updateFileMeta();
  updateProductFieldsState();
  updateOutputs();
</script>
