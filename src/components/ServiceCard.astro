---
import type { ServiceItem } from '../data/types';
import CTAButton from './CTAButton.astro';
import { bookSessionClick, printBuyClick } from '../utils/analytics';

interface Props {
  service: ServiceItem;
  context?: string;
}

const { service, context = 'service_card' } = Astro.props;
const isPrintService = service.slug === 'prints';
---

<article class="surface flex h-full flex-col transition-colors duration-300 hover:border-platinum/30 hover:bg-dusk/80">
  {service.imageSrc && (
    <img
      alt={`${service.title} supporting image`}
      class="aspect-[5/4] w-full rounded-t-panel object-cover"
      height="960"
      loading="lazy"
      src={service.imageSrc}
      width="1200"
    />
  )}
  <div class="flex flex-1 flex-col space-y-5 p-6">
    <span class="text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-sage">{service.title}</span>
    <h3 class="text-2xl leading-tight text-paper">{service.shortDescription}</h3>
    <p class="text-sm leading-relaxed text-steel">{service.longDescription}</p>
    {service.startingPrice && <p class="text-sm font-semibold text-paper">{service.startingPrice}</p>}
    <div class="mt-auto pt-2">
      <CTAButton
        class="whitespace-nowrap"
        href={service.pageHref}
        label={service.slug === 'prints' ? 'View Print Options' : service.ctaLabel}
        tracking={
          isPrintService
            ? printBuyClick({ location: context, service: service.slug })
            : bookSessionClick({ location: context, service: service.slug })
        }
        trackingMeta={{
          'data-link-type': isPrintService ? 'print_browse' : 'booking_inquiry',
          'data-link-location': context,
          'data-link-service': service.slug,
        }}
        variant="secondary"
      />
    </div>
  </div>
</article>
