---
import type { ImageItem } from '../data/types';
import { getImageCategoryLabel } from '../data/categories';
import { galleryImageClick } from '../utils/analytics';

interface Props {
  image: ImageItem;
  eager?: boolean;
  showCategory?: boolean;
  context?: string;
}

const {
  image,
  eager = false,
  showCategory = true,
  context = 'gallery_card',
} = Astro.props;

const aspectClass =
  image.orientation === 'horizontal'
    ? 'aspect-[6/4]'
    : image.orientation === 'square'
      ? 'aspect-square'
      : 'aspect-[4/5]';
const categoryLabel = getImageCategoryLabel(image.category);
---

<article class="group">
  <a
    class="panel-link block"
    href={`/p/${image.slug}/`}
    {...galleryImageClick({
      imageSlug: image.slug,
      category: image.category,
      location: context,
    })}
  >
    <div class={`image-frame transition-colors duration-300 group-hover:border-platinum/35 ${aspectClass}`}>
      <img
        alt={image.alt}
        class="h-full w-full object-cover transition duration-700 ease-luxury group-hover:scale-[1.025] group-hover:opacity-95"
        decoding="async"
        height="1600"
        loading={eager ? 'eager' : 'lazy'}
        sizes="(min-width: 1280px) 30vw, (min-width: 640px) 45vw, calc(100vw - 2.5rem)"
        src={image.imageSrc}
        width="1200"
      />
    </div>
    <div class="space-y-2 pt-4">
      {showCategory && <span class="text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-sage">{categoryLabel}</span>}
      <h3 class="text-2xl leading-tight text-paper transition-colors group-hover:text-sand">{image.title}</h3>
      <p class="text-sm leading-relaxed text-steel">{image.hook}</p>
      <span class="inline-flex items-center text-sm font-semibold text-sand underline decoration-platinum/20 underline-offset-4 transition-colors group-hover:text-paper group-hover:decoration-platinum/70">
        Open photograph
      </span>
    </div>
  </a>
</article>
