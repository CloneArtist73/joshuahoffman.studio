---
type Variant = 'primary' | 'secondary' | 'ghost';

interface Props {
  href: string;
  label: string;
  variant?: Variant;
  external?: boolean;
  tracking?: Record<string, string>;
  class?: string;
}

const {
  href,
  label,
  variant = 'primary',
  external = false,
  tracking = {},
  class: className = '',
} = Astro.props;

const variantClasses: Record<Variant, string> = {
  primary:
    'border border-ember/70 bg-ember px-5 py-3 text-obsidian shadow-soft hover:border-ember hover:bg-[#d48b63]',
  secondary:
    'border border-white/10 bg-white/5 px-5 py-3 text-paper hover:border-sage/60 hover:bg-white/10',
  ghost:
    'border border-transparent px-4 py-3 text-sand hover:bg-white/10 hover:text-paper',
};
---

<a
  href={href}
  class:list={[
    'panel-link inline-flex items-center justify-center rounded-full text-sm font-semibold tracking-wide',
    variantClasses[variant],
    className,
  ]}
  rel={external ? 'noreferrer noopener' : undefined}
  target={external ? '_blank' : undefined}
  {...tracking}
>
  {label}
</a>
