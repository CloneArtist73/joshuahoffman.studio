---
type Variant = 'primary' | 'secondary' | 'ghost';

interface Props {
  href: string;
  label: string;
  variant?: Variant;
  external?: boolean;
  tracking?: Record<string, string>;
  trackingMeta?: Record<string, string>;
  class?: string;
}

const {
  href,
  label,
  variant = 'primary',
  external = false,
  tracking = {},
  trackingMeta = {},
  class: className = '',
} = Astro.props;

const variantClasses: Record<Variant, string> = {
  primary: 'btn-primary',
  secondary: 'btn-secondary',
  ghost: 'btn-ghost',
};

const inferredLinkType = external
  ? 'print_purchase'
  : href.includes('/contact')
    ? 'booking_inquiry'
    : 'cta_click';

const baseTrackingMeta = {
  'data-link-type': inferredLinkType,
  'data-link-label': label,
  'data-link-href': href,
};
---

<a
  href={href}
  class:list={[
    'btn',
    variantClasses[variant],
    className,
  ]}
  rel={external ? 'noreferrer noopener' : undefined}
  target={external ? '_blank' : undefined}
  {...tracking}
  {...baseTrackingMeta}
  {...trackingMeta}
>
  <span>{label}</span>
</a>
