---
import CTAButton from './CTAButton.astro';
import { externalLinks } from '../data/externalLinks';
import { printBuyClick, contactClick } from '../utils/analytics';

interface Props {
  routeKeys: string[];
  imageSlug: string;
  productSlug: string;
  includeInquiry?: boolean;
  inquiryHref?: string;
  compact?: boolean;
}

const {
  routeKeys,
  imageSlug,
  productSlug,
  includeInquiry = false,
  inquiryHref = `/contact/?type=Print%20or%20product%20question&image=${encodeURIComponent(imageSlug)}`,
  compact = false,
} = Astro.props;

function isLiveRoute(route: (typeof externalLinks)[string]) {
  const hasTemplateToken = route.url.includes('{imageSlug}') || route.url.includes('{productSlug}');
  const markedPlaceholder = /replace with|before launch|once .* finalized/i.test(route.note ?? '');

  return !hasTemplateToken && !markedPlaceholder;
}

const routes = routeKeys
  .map((routeKey) => externalLinks[routeKey])
  .filter((route): route is (typeof externalLinks)[string] => Boolean(route))
  .filter(isLiveRoute);
const hasRoutes = routes.length > 0;

function getRouteUrl(url: string) {
  return url
    .replace('{imageSlug}', encodeURIComponent(imageSlug))
    .replace('{productSlug}', encodeURIComponent(productSlug));
}
---

<div class={`flex flex-wrap items-center gap-3 ${compact ? 'p-0' : 'pt-2'}`}>
  {
    routes.map((route) => (
      <CTAButton
        external
        href={getRouteUrl(route.url)}
        label={route.label}
        tracking={printBuyClick(
          {
            imageSlug,
            productSlug,
            platform: route.platform,
          },
          route.platform,
        )}
        trackingMeta={{
          'data-link-type': 'print_purchase',
          'data-link-platform': route.platform,
          'data-link-label': route.label,
          'data-link-image': imageSlug,
          'data-link-product': productSlug,
        }}
        variant="secondary"
      />
    ))
  }
  {
    includeInquiry && (
      <CTAButton
        href={inquiryHref}
        label={hasRoutes ? 'Ask About Custom Print' : 'Ask About This Print'}
        tracking={contactClick({
          location: 'product_routes',
          imageSlug,
          productSlug,
          intent: 'custom_print',
        })}
        trackingMeta={{
          'data-link-type': 'booking_inquiry',
          'data-link-intent': 'custom_print',
          'data-link-location': 'product_routes',
          'data-link-image': imageSlug,
          'data-link-product': productSlug,
        }}
        variant={hasRoutes ? 'ghost' : 'primary'}
      />
    )
  }
  {
    !includeInquiry && !hasRoutes && (
      <p class="text-sm text-steel">
        Direct print availability is handled by request for this image.
      </p>
    )
  }
</div>
