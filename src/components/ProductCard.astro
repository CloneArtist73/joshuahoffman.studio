---
import type { ImageItem, ProductItem } from '../data/types';
import ProductRouteButtons from './ProductRouteButtons.astro';

interface Props {
  product: ProductItem;
  image: ImageItem;
}

const { product, image } = Astro.props;
const availableFormats =
  product.availableFormats.length > 0 ? product.availableFormats.join(' · ') : 'Custom sizing by inquiry';
---

<article class="surface flex h-full flex-col overflow-hidden transition-colors duration-300 hover:border-platinum/30 hover:bg-dusk/80">
  <a class="panel-link group block shrink-0 focus-visible:ring-inset focus-visible:ring-offset-0" href={`/p/${image.slug}/`}>
    <img
      alt={image.alt}
      class="aspect-[5/4] w-full object-cover transition duration-700 ease-luxury group-hover:scale-[1.025] group-hover:opacity-95"
      decoding="async"
      height="1000"
      loading="lazy"
      sizes="(min-width: 1024px) 45vw, calc(100vw - 2.5rem)"
      src={image.imageSrc}
      width="1200"
    />
  </a>
  <div class="flex flex-1 flex-col space-y-4 p-6">
    <div class="space-y-2">
      <span class="text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-sage">Physical print</span>
      <h3 class="text-2xl leading-tight text-paper">{product.title}</h3>
      <p class="text-sm leading-relaxed text-steel">{product.shortDescription}</p>
    </div>
    <dl class="grid gap-3 border-t border-white/10 pt-4 text-sm">
      <div>
        <dt class="font-semibold text-paper">Available sizes</dt>
        <dd class="mt-1 text-steel">{availableFormats}</dd>
      </div>
      <div>
        <dt class="font-semibold text-paper">Ordering</dt>
        <dd class="mt-1 text-steel">Confirmed storefront link when available; direct inquiry for paper, signed work, availability, and custom sizing.</dd>
      </div>
    </dl>
    <div class="mt-auto pt-1">
      <ProductRouteButtons
        imageSlug={image.slug}
        includeInquiry={product.inquiryAllowed}
        productSlug={product.slug}
        routeKeys={product.routeKeys}
      />
    </div>
  </div>
</article>
