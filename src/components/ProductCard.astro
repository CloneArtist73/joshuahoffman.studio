---
import type { ImageItem, ProductItem } from '../data/types';
import ProductRouteButtons from './ProductRouteButtons.astro';

interface Props {
  product: ProductItem;
  image: ImageItem;
}

const { product, image } = Astro.props;
---

<article class="surface flex h-full flex-col">
  <a class="panel-link block shrink-0 rounded-t-panel focus-visible:ring-inset focus-visible:ring-offset-0" href={`/p/${image.slug}/`}>
    <img
      alt={image.alt}
      class="aspect-[5/4] w-full rounded-t-panel object-cover"
      decoding="async"
      height="1000"
      loading="lazy"
      sizes="(min-width: 1024px) 45vw, calc(100vw - 2.5rem)"
      src={image.imageSrc}
      width="1200"
    />
  </a>
  <div class="flex flex-1 flex-col space-y-4 p-6">
    <div class="space-y-2">
      <span class="tag-pill">Prints</span>
      <h3 class="text-2xl">{product.title}</h3>
      <p class="text-sm text-steel">{product.shortDescription}</p>
    </div>
    <dl class="grid gap-3 border-t border-white/10 pt-4 text-sm">
      <div>
        <dt class="font-semibold text-paper">Available sizes</dt>
        <dd class="mt-1 text-steel">{product.availableFormats.join(' · ')}</dd>
      </div>
      <div>
        <dt class="font-semibold text-paper">Ordering</dt>
        <dd class="mt-1 text-steel">Direct inquiry for paper, availability, signed work, and custom sizing.</dd>
      </div>
    </dl>
    <div class="mt-auto pt-1">
      <ProductRouteButtons
        imageSlug={image.slug}
        includeInquiry={product.inquiryAllowed}
        productSlug={product.slug}
        routeKeys={product.routeKeys}
      />
    </div>
  </div>
</article>
