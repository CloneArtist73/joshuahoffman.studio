---
import ImageCard from './ImageCard.astro';
import type { ImageCategory, ImageItem } from '../data/types';

interface Props {
  images: ImageItem[];
  heading?: string;
  intro?: string;
  enableFilter?: boolean;
  id?: string;
  context?: string;
}

const {
  images,
  heading,
  intro,
  enableFilter = false,
  id = 'gallery-grid',
  context = 'gallery_grid',
} = Astro.props;

const categoryLabels: Record<ImageCategory, string> = {
  portrait: 'Portraits',
  legacy: 'Legacy',
  musician: 'Musicians',
  print: 'Prints',
  personal: 'Personal Work',
};

const categories = [...new Set(images.map((image) => image.category))];
---

<section class="section-block">
  <div class="shell">
    {
      (heading || intro) && (
        <div class="max-w-3xl space-y-4">
          {heading && <h2 class="text-3xl sm:text-4xl">{heading}</h2>}
          {intro && <p class="text-base text-steel sm:text-lg">{intro}</p>}
        </div>
      )
    }

    {
      enableFilter && (
        <div class="mt-8 flex flex-wrap gap-3" data-filter-controls>
          <button
            aria-pressed="true"
            class="panel-link min-h-11 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm font-semibold text-paper"
            data-filter="all"
            type="button"
          >
            All
          </button>
          {
            categories.map((category) => (
      <button
        aria-pressed="false"
        class="panel-link min-h-11 rounded-full border border-white/10 px-4 py-2 text-sm font-semibold text-steel transition focus-visible:ring-2 focus-visible:ring-platinum/70 hover:border-platinum/60 hover:text-paper"
        data-filter={category}
        type="button"
      >
        {categoryLabels[category]}
      </button>
            ))
          }
        </div>
      )
    }

    <div class="mt-10 grid items-start gap-6 sm:grid-cols-2 xl:grid-cols-3" id={id}>
      {
        images.map((image, index) => (
          <div data-gallery-card data-category={image.category}>
            <ImageCard
              context={context}
              eager={index < 2}
              image={image}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

{
  enableFilter && (
    <script define:vars={{ gridId: id }} is:inline>
      const galleryGrid = document.getElementById(gridId);
      const section = galleryGrid?.closest('section');
      const buttons = Array.from(section?.querySelectorAll('[data-filter]') ?? []);
      const cards = Array.from(galleryGrid?.querySelectorAll('[data-gallery-card]') ?? []);

      function updateFilter(filter) {
      buttons.forEach((button) => {
        const isActive = button.dataset.filter === filter;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('bg-white/10', isActive);
        button.classList.toggle('border-platinum/70', isActive);
        button.classList.toggle('shadow-soft', isActive);
        button.classList.toggle('text-paper', isActive);
        button.classList.toggle('text-steel', !isActive);
      });

        cards.forEach((card) => {
          const matches = filter === 'all' || card.dataset.category === filter;
          card.hidden = !matches;
        });
      }

      buttons.forEach((button) => {
        button.addEventListener('click', () => updateFilter(button.dataset.filter || 'all'));
      });
    </script>
  )
}
