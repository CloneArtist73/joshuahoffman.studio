---
import CTAButton from '../components/CTAButton.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import Hero from '../components/Hero.astro';
import Layout from '../components/Layout.astro';
import { getImageBySlug, isPublicImage } from '../data/images';
import { getServiceBySlug } from '../data/services';
import { bookSessionClick } from '../utils/analytics';

const service = getServiceBySlug('musician');
if (!service) {
  throw new Error('Musician service data is missing.');
}

const galleryImages = service.gallerySlugs
  .map((slug) => getImageBySlug(slug))
  .filter((image): image is NonNullable<ReturnType<typeof getImageBySlug>> => image !== undefined && isPublicImage(image));

const musicianUseCases = [
  'Press photos',
  'Album and cover visuals',
  'Promo images',
  'Social and media kit portraits',
];
---

<Layout
  description={service.longDescription}
  path="/musicians/"
  title="Musician and Artist Portraits"
>
  <Hero
    eyebrow="Musician / artist portraits"
    imageSrc={service.imageSrc}
    primaryCta={{
      label: service.ctaLabel,
      href: '/contact/?type=Musician%20%2F%20artist%20portraits',
      eventName: 'book_session_click',
      eventProps: {
        service: service.slug,
        location: 'musicians_hero',
      },
    }}
    secondaryCta={{
      label: 'View Prints',
      href: '/prints/',
      eventName: 'print_buy_click',
      eventProps: {
        location: 'musicians_hero',
        destination: 'prints_page',
      },
    }}
    text={service.heroBody}
    title={service.heroTitle}
  />

  <section class="section-block section-rule">
    <div class="shell grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
      <div class="space-y-4">
        <span class="eyebrow">Artist work</span>
        <p class="editorial-statement">
          The photograph has to work where the music is judged quickly: posters, press, release pages, and small screens.
        </p>
        <p class="max-w-copy text-base leading-relaxed text-steel sm:text-lg">
          Planning starts with sound, references, use, and timing so the session produces images with enough friction to feel connected to the work.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        <article class="surface p-6 sm:p-8">
          <span class="eyebrow">Built for</span>
          <ul class="quiet-list mt-5">
            {service.idealFor.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="surface p-6 sm:p-8">
          <span class="eyebrow">Use cases</span>
          <ul class="quiet-list mt-5">
            {musicianUseCases.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="surface p-6 sm:p-8">
          <span class="eyebrow">What this includes</span>
          <ul class="quiet-list mt-5">
            {service.includes.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  {
    galleryImages.length > 0 && (
      <GalleryGrid
        context="musicians_supporting_gallery"
        heading="Artist-focused images"
        images={galleryImages}
        intro="Press photos, promo frames, and images that can sit on posters, release pages, and social without feeling generic."
      />
    )
  }

  <section class="section-block section-rule">
    <div class="shell">
      <div class="flex flex-col gap-5 border-y border-platinum/10 py-10 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-3xl">Need work that feels closer to the sound than the template?</h2>
          <p class="mt-3 max-w-copy text-steel">
            Send a message with your project, timeline, and where the images need to work first.
          </p>
        </div>
        <CTAButton
          href="/contact/?type=Musician%20%2F%20artist%20portraits"
          label={service.ctaLabel}
          tracking={bookSessionClick({ service: service.slug, location: 'musicians_footer_cta' })}
        />
      </div>
    </div>
  </section>
</Layout>
