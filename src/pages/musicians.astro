---
import CTAButton from '../components/CTAButton.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import Hero from '../components/Hero.astro';
import Layout from '../components/Layout.astro';
import { getImageBySlug } from '../data/images';
import { getServiceBySlug } from '../data/services';
import { bookSessionClick } from '../utils/analytics';

const service = getServiceBySlug('musician');
if (!service) {
  throw new Error('Musician service data is missing.');
}

const galleryImages = service.gallerySlugs
  .map((slug) => getImageBySlug(slug))
  .filter((image): image is NonNullable<ReturnType<typeof getImageBySlug>> => Boolean(image));

const musicianUseCases = [
  'Press photos',
  'Album and cover visuals',
  'Promo images',
  'Social and media kit portraits',
];
---

<Layout
  description={service.longDescription}
  path="/musicians/"
  title="Musician and Artist Portraits"
>
  <Hero
    eyebrow="Musician / artist portraits"
    imageAlt="Illustrative musician portrait image."
    imageSrc={service.imageSrc ?? '/images/placeholders/musician-stage.svg'}
    primaryCta={{
      label: service.ctaLabel,
      href: '/contact/?type=Musician%20%2F%20artist%20portraits',
      eventName: 'book_session_click',
      eventProps: {
        service: service.slug,
        location: 'musicians_hero',
      },
    }}
    secondaryCta={{
      label: 'View Prints',
      href: '/prints/',
      eventName: 'print_buy_click',
      eventProps: {
        location: 'musicians_hero',
        destination: 'prints_page',
      },
    }}
    text={service.heroBody}
    title={service.heroTitle}
  />

  <section class="section-block pt-0">
    <div class="shell grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <article class="surface p-6 sm:p-8">
        <span class="eyebrow">Built for</span>
        <div class="mt-5 space-y-3">
          {service.idealFor.map((item) => <p class="text-steel">{item}</p>)}
        </div>
      </article>
      <article class="surface p-6 sm:p-8">
        <span class="eyebrow">Use cases</span>
        <div class="mt-5 space-y-3">
          {musicianUseCases.map((item) => <p class="text-steel">{item}</p>)}
        </div>
      </article>
    </div>
  </section>

  <GalleryGrid
    context="musicians_supporting_gallery"
    heading="Artist-focused images"
    images={galleryImages}
    intro="Press photos, promo frames, and images that can sit on posters, release pages, and social without feeling generic."
  />

  <section class="section-block pt-0">
    <div class="shell">
      <div class="surface flex flex-col gap-4 p-8 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-3xl">Need work that feels closer to the sound than the template?</h2>
          <p class="mt-3 max-w-copy text-steel">
            Send a message with your project, timeline, and where the images need to work first.
          </p>
        </div>
        <CTAButton
          href="/contact/?type=Musician%20%2F%20artist%20portraits"
          label={service.ctaLabel}
          tracking={bookSessionClick({ service: service.slug, location: 'musicians_footer_cta' })}
        />
      </div>
    </div>
  </section>
</Layout>
