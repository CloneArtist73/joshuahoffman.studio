---
import CTAButton from '../components/CTAButton.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import Hero from '../components/Hero.astro';
import Layout from '../components/Layout.astro';
import { getImageBySlug, isPublicImage } from '../data/images';
import { getServiceBySlug } from '../data/services';
import { bookSessionClick } from '../utils/analytics';

const service = getServiceBySlug('portrait');
if (!service) {
  throw new Error('Portrait service data is missing.');
}

const galleryImages = service.gallerySlugs
  .map((slug) => getImageBySlug(slug))
  .filter((image): image is NonNullable<ReturnType<typeof getImageBySlug>> => Boolean(image) && isPublicImage(image));
---

<Layout
  description={service.longDescription}
  path="/portraits/"
  title="Portrait Sessions"
>
  <Hero
    eyebrow="Portrait sessions"
    imageSrc={service.imageSrc ?? '/images/placeholders/portrait-session.svg'}
    primaryCta={{
      label: service.ctaLabel,
      href: '/contact/?type=Portrait%20session',
      eventName: 'book_session_click',
      eventProps: {
        service: service.slug,
        location: 'portraits_hero',
      },
    }}
    secondaryCta={{
      label: 'Explore Gallery',
      href: '/gallery/',
      eventName: 'gallery_image_click',
      eventProps: {
        location: 'portraits_hero',
        destination: 'gallery',
      },
    }}
    text={service.heroBody}
    title={service.heroTitle}
  />

  <section class="section-block pt-0">
    <div class="shell grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <article class="surface p-6 sm:p-8">
        <span class="eyebrow">Who this is for</span>
        <div class="mt-5 space-y-3">
          {service.idealFor.map((item) => <p class="text-steel">{item}</p>)}
        </div>
      </article>
      <article class="surface p-6 sm:p-8">
        <span class="eyebrow">What the session includes</span>
        <div class="mt-5 space-y-3">
          {service.includes.map((item) => <p class="text-steel">{item}</p>)}
        </div>
        {service.startingPrice && <p class="mt-6 text-sm font-semibold text-paper">{service.startingPrice}</p>}
      </article>
    </div>
  </section>

  {
    galleryImages.length > 0 && (
      <GalleryGrid
        context="portraits_supporting_gallery"
        heading="Portrait examples"
        images={galleryImages}
        intro="A small supporting edit so visitors can quickly understand the tone of the work."
      />
    )
  }

  <section class="section-block pt-0">
    <div class="shell">
      <div class="surface flex flex-col gap-4 p-8 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-3xl">Ready to make something direct and usable?</h2>
          <p class="mt-3 max-w-copy text-steel">
            Start with a message about who the portraits are for, where they will be used, and when you need them.
          </p>
        </div>
        <CTAButton
          href="/contact/?type=Portrait%20session"
          label={service.ctaLabel}
          tracking={bookSessionClick({ service: service.slug, location: 'portraits_footer_cta' })}
        />
      </div>
    </div>
  </section>
</Layout>
