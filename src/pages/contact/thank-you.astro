---
import CTAButton from '../../components/CTAButton.astro';
import Layout from '../../components/Layout.astro';
---

<Layout
  description="Thank you page shown after the static contact form is submitted."
  noindex
  path="/contact/thank-you/"
  title="Thank You"
>
  <section class="section-block">
    <div class="shell">
      <div class="surface mx-auto max-w-3xl space-y-6 p-8 text-center sm:p-10">
        <span class="eyebrow">Thank you</span>
        <h1 class="text-4xl sm:text-5xl">Thank you. I got your message and will reply directly.</h1>
        <p class="mx-auto max-w-copy text-base text-steel sm:text-lg">
          If your note is time-sensitive, you can also reach Joshua directly by email from the contact page.
        </p>
        <div class="flex flex-col justify-center gap-3 sm:flex-row">
          <CTAButton href="/gallery/" label="View the Gallery" variant="secondary" />
          <CTAButton href="/" label="Back to Home" />
        </div>
      </div>
    </div>
  </section>
</Layout>
