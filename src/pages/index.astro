---
import GalleryGrid from '../components/GalleryGrid.astro';
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTAButton from '../components/CTAButton.astro';
import { getFeaturedImages, getImageBySlug, isPublicImage } from '../data/images';
import { products } from '../data/products';
import { services } from '../data/services';
import { siteConfig } from '../data/site';
import { contactClick } from '../utils/analytics';
import { isPublicReadyProduct } from '../utils/readiness';

const featuredImages = getFeaturedImages(6);
const previewProducts = products
  .map((product) => ({
    product,
    image: getImageBySlug(product.imageSlug),
  }))
  .filter((entry): entry is { product: (typeof products)[number]; image: NonNullable<ReturnType<typeof getImageBySlug>> } =>
    entry.image !== undefined && isPublicImage(entry.image) && isPublicReadyProduct(entry.product, entry.image),
  )
  .slice(0, 3);

const hasPrintProducts = previewProducts.length > 0;
const heroSecondaryImages = featuredImages.slice(0, 2);
const trustNotes = [
  ['Work', 'Portraits, legacy photography, musician images, and selected prints'],
  ['Area', siteConfig.serviceArea],
  ['Next step', 'A short inquiry, then a direct reply from Joshua'],
] as const;
---

<Layout
  description={siteConfig.heroSupport}
  ogImage="/images/ice-formations-on-a-surface.jpeg"
  path="/"
  title="Portraits, memory work, musician images, and prints with emotional weight"
>
  <section class="section-block overflow-hidden pt-10 sm:pt-14">
    <div class="shell grid gap-10 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-center">
      <div class="space-y-7">
        <div class="space-y-5">
          <span class="eyebrow">Joshua Hoffman Studio · {siteConfig.serviceArea}</span>
          <h1 class="headline max-w-4xl">{siteConfig.heroHeadline}</h1>
          <p class="max-w-copy text-base leading-relaxed text-steel sm:text-lg">
            {siteConfig.heroSupport} The site is built as a direct visual path: look at the work, choose the right kind of inquiry, and start a specific conversation.
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row">
          <CTAButton
            href="/contact/"
            label="Start an Inquiry"
            tracking={contactClick({ location: 'homepage_hero_primary' })}
            trackingMeta={{
              'data-link-intent': 'general_inquiry',
              'data-link-location': 'homepage_hero_primary',
            }}
          />
          <CTAButton
            href="/gallery/"
            label="View the Work"
            trackingMeta={{
              'data-link-type': 'gallery_navigation',
              'data-link-location': 'homepage_hero_secondary',
            }}
            variant="secondary"
          />
        </div>

        <dl class="grid gap-4 border-t border-platinum/10 pt-6 sm:grid-cols-3">
          {trustNotes.map(([label, value]) => (
            <div>
              <dt class="text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-sage">{label}</dt>
              <dd class="mt-1 text-sm leading-relaxed text-steel">{value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="grid gap-4 sm:grid-cols-[0.72fr_1.28fr] lg:gap-5">
        <figure class="image-frame sm:col-start-2 sm:row-span-2">
          <img
            alt="Close detail of ice formations with quiet texture and muted light."
            class="aspect-[4/5] w-full object-cover sm:aspect-[5/6] lg:aspect-[4/5]"
            decoding="async"
            fetchpriority="high"
            height="1320"
            loading="eager"
            sizes="(min-width: 1024px) 50vw, calc(100vw - 2.5rem)"
            src="/images/ice-formations-on-a-surface.jpeg"
            width="990"
          />
        </figure>

        {heroSecondaryImages.map((image, index) => (
          <a
            class="panel-link group hidden overflow-hidden rounded-panel border border-platinum/15 bg-black sm:block"
            href={`/p/${image.slug}/`}
          >
            <img
              alt={image.alt}
              class:list={[
                'w-full object-cover transition duration-700 ease-luxury group-hover:scale-[1.025] group-hover:opacity-95',
                index === 0 ? 'aspect-square' : 'aspect-[4/5]',
              ]}
              decoding="async"
              height="900"
              loading="eager"
              sizes="(min-width: 1024px) 18vw, 28vw"
              src={image.imageSrc}
              width="720"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block section-rule">
    <div class="shell space-y-8">
      <div class="grid gap-6 lg:grid-cols-[0.86fr_1.14fr] lg:items-end">
        <div class="max-w-3xl space-y-4">
        <span class="eyebrow">Choose the right path</span>
        <h2 class="text-3xl sm:text-4xl">Portraits, legacy work, musician sessions, and prints.</h2>
        <p class="text-base leading-relaxed text-steel sm:text-lg">
          Start with the kind of work you need, then move into a focused gallery or a direct inquiry when something feels close.
        </p>
        </div>
        <p class="editorial-statement max-w-2xl lg:justify-self-end">
          The work should feel specific before the session, print, or license conversation begins.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
        {services.map((service) => <ServiceCard context="homepage_path_cards" service={service} />)}
      </div>
    </div>
  </section>

  <GalleryGrid
    context="homepage_featured_gallery"
    heading="Featured work"
    images={featuredImages}
    intro="A compact edit of finished photographs: night sky, city geometry, quiet scale, and print-ready frames."
  />

  <section class="section-block section-rule">
    <div class="shell space-y-8">
      <div class="max-w-3xl space-y-4">
        <span class="eyebrow">Selected prints</span>
        <h2 class="text-3xl sm:text-4xl">Photographs that can live beyond a screen.</h2>
        <p class="text-base leading-relaxed text-steel sm:text-lg">
          Browse a small print edit, then ask directly about sizing, availability, signed work, or licensing.
        </p>
      </div>

      <div class="overflow-hidden -mx-5 px-5 sm:mx-0 sm:px-0">
        <!-- Mobile: Snap Scroller -->
        <div class="flex flex-nowrap overflow-x-auto snap-x snap-mandatory gap-5 pb-8 no-scrollbar touch-auto sm:hidden">
          {previewProducts.map(({ product, image }) => (
            <div class="w-[85vw] flex-none snap-center">
              <ProductCard image={image} product={product} />
            </div>
          ))}
          <div class="w-1 flex-none h-1"></div>
        </div>

        <!-- Desktop: Grid -->
        <div class="hidden sm:grid gap-6 lg:grid-cols-3">
          {hasPrintProducts ? (
            previewProducts.map(({ product, image }) => <ProductCard image={image} product={product} />)
          ) : (
            <article class="surface p-6 text-sm text-steel">
              Selected print inquiries are handled directly. Use contact options below for custom sizing, signed work, or availability.
            </article>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="section-block section-rule">
    <div class="shell">
      <div class="grid gap-8 border-y border-platinum/10 py-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div class="space-y-4">
          <span class="eyebrow">Inquiry</span>
          <h2 class="text-3xl sm:text-4xl">Need portraits, legacy work, a print question, or something harder to categorize?</h2>
          <p class="max-w-copy text-base leading-relaxed text-steel sm:text-lg">
            Start with a short message. Joshua replies directly about portraits, memorial work, musician sessions, prints, licensing, and the practical details around each.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
          <CTAButton
            href="/contact/"
            label="Start an Inquiry"
            tracking={contactClick({ location: 'homepage_inquiry_block' })}
            trackingMeta={{
              'data-link-intent': 'contact',
              'data-link-location': 'homepage_inquiry_block',
            }}
          />
          <CTAButton
            href="/gallery/"
            label="Explore Gallery"
            trackingMeta={{
              'data-link-type': 'gallery_navigation',
              'data-link-location': 'homepage_inquiry_block',
            }}
            variant="secondary"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
