---
import GalleryGrid from '../components/GalleryGrid.astro';
import Hero from '../components/Hero.astro';
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTAButton from '../components/CTAButton.astro';
import { ctas } from '../data/ctas';
import { getFeaturedImages, getImageBySlug } from '../data/images';
import { products } from '../data/products';
import { services } from '../data/services';
import { siteConfig } from '../data/site';
import { contactClick } from '../utils/analytics';

const featuredImages = getFeaturedImages(6);
const previewProducts = products.slice(0, 3)
  .map((product) => ({
    product,
    image: getImageBySlug(product.imageSlug),
  }))
  .filter((entry): entry is { product: (typeof products)[number]; image: NonNullable<ReturnType<typeof getImageBySlug>> } => Boolean(entry.image));
---

<Layout
  description={siteConfig.heroSupport}
  ogImage="/images/placeholders/hero-memory.svg"
  path="/"
  title="Portraits, memory work, musician images, and prints with emotional weight"
>
  <Hero
    eyebrow="Static MVP"
    imageAlt="Placeholder artwork for the homepage hero image."
    imageSrc="/images/placeholders/hero-memory.svg"
    primaryCta={ctas.bookPortrait}
    secondaryCta={ctas.viewPrints}
    text={siteConfig.heroSupport}
    title={siteConfig.heroHeadline}
  />

  <section class="section-block pt-0">
    <div class="shell space-y-8">
      <div class="max-w-3xl space-y-4">
        <span class="eyebrow">Choose the right path</span>
        <h2 class="text-3xl sm:text-4xl">Portraits, legacy work, musician sessions, and prints.</h2>
        <p class="text-base text-steel sm:text-lg">
          The homepage keeps the first visit simple: see the work, understand what Joshua photographs, and move toward the right next step.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
        {services.map((service) => <ServiceCard context="homepage_path_cards" service={service} />)}
      </div>
    </div>
  </section>

  <GalleryGrid
    context="homepage_featured_gallery"
    heading="Featured work"
    images={featuredImages}
    intro="A short edited gallery built to show emotional range without dumping the full archive onto the homepage."
  />

  <section class="section-block pt-0">
    <div class="shell space-y-8">
      <div class="max-w-3xl space-y-4">
        <span class="eyebrow">Print router</span>
        <h2 class="text-3xl sm:text-4xl">Selected photographs ready for outbound checkout.</h2>
        <p class="text-base text-steel sm:text-lg">
          This MVP does not build custom ecommerce. It sends buyers toward trusted storefronts and leaves room for direct print questions.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {previewProducts.map(({ product, image }) => <ProductCard image={image} product={product} />)}
      </div>
    </div>
  </section>

  <section class="section-block pt-0">
    <div class="shell">
      <div class="surface grid gap-8 p-8 sm:p-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div class="space-y-4">
          <span class="eyebrow">Inquiry</span>
          <h2 class="text-3xl sm:text-4xl">Need portraits, legacy work, a print question, or something harder to categorize?</h2>
          <p class="max-w-copy text-base text-steel sm:text-lg">
            Start with a short message. Joshua can reply directly about portraits, memorial work, musician sessions, prints, or licensing.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
          <CTAButton
            href="/contact/"
            label="Start an Inquiry"
            tracking={contactClick({ location: 'homepage_inquiry_block' })}
          />
          <CTAButton href="/gallery/" label="Explore Gallery" variant="secondary" />
        </div>
      </div>
    </div>
  </section>
</Layout>
