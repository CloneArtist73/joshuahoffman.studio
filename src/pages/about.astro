---
import CTAButton from '../components/CTAButton.astro';
import Layout from '../components/Layout.astro';
import { siteConfig } from '../data/site';
import { contactClick } from '../utils/analytics';

const trustNotes = [
  {
    label: 'Service area',
    text: siteConfig.serviceArea,
  },
  {
    label: 'Primary work',
    text: 'Portraits, legacy photography, musician images, selected prints, and licensing conversations.',
  },
  {
    label: 'Inquiry path',
    text: 'Start with a short note; Joshua replies directly so timing, privacy, location, and use can be handled clearly.',
  },
];

const processSteps = [
  'Share what you need, who the photographs are for, and any timing that matters.',
  'Narrow the use, location, privacy needs, and deliverables before a session is planned.',
  'Keep the edit focused so finished images feel useful, personal, and easy to revisit.',
];
---

<Layout
  description="Short trust page explaining what Joshua photographs, why the work matters, and where he works."
  path="/about/"
  title="About"
>
  <section class="section-block">
    <div class="shell grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div class="surface order-2 space-y-8 p-6 sm:p-8">
        <span class="eyebrow">Working approach</span>
        <div class="space-y-5">
          <div>
            <h2 class="text-2xl">Quiet direction</h2>
            <p class="mt-2 text-sm text-steel">
              Sessions are shaped around presence, pacing, and photographs that still feel like the person after the moment passes.
            </p>
          </div>
          <div>
            <h2 class="text-2xl">Clear next steps</h2>
            <p class="mt-2 text-sm text-steel">
              Start with a short note, then narrow the location, use, privacy needs, and deliverables before a session is planned.
            </p>
          </div>
          <div>
            <h2 class="text-2xl">Work that can be revisited</h2>
            <p class="mt-2 text-sm text-steel">
              The site centers portraits, memory work, artist images, and selected prints that hold up beyond a quick scroll.
            </p>
          </div>
        </div>
        <dl class="space-y-4 border-t border-white/10 pt-6">
          {trustNotes.map((item) => (
            <div>
              <dt class="text-xs font-semibold uppercase tracking-hush text-steel">{item.label}</dt>
              <dd class="mt-1 text-sm text-paper">{item.text}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="order-1 space-y-5">
        <span class="eyebrow">About Joshua</span>
        <h1 class="headline max-w-4xl">Joshua photographs people, rooms, artists, and memory with as little noise as possible.</h1>
        <div class="rich-copy max-w-copy">
          <p>
            This site is built to show emotional work clearly: portraits that feel like the person, legacy images that treat memory carefully, and prints that can live outside a screen.
          </p>
          <p>
            The work stays grounded in family, grief, music, ordinary rooms, and the weight people carry in their faces and hands. It is made for people who want more than a pose.
          </p>
          <p>
            Service area: {siteConfig.serviceArea}.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <CTAButton
            href="/contact/"
            label="Contact Joshua"
            tracking={contactClick({ location: 'about_primary_cta' })}
          />
          <CTAButton href="/gallery/" label="View the Gallery" variant="secondary" />
        </div>
      </div>
    </div>
  </section>

  <section class="section-block section-rule">
    <div class="shell">
      <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <div class="max-w-2xl space-y-4">
          <span class="eyebrow">What happens next</span>
          <h2 class="text-3xl sm:text-4xl">A direct path from first note to finished images.</h2>
          <p class="text-base text-steel sm:text-lg">
            The process stays visible from the first message, so you know what to share and what Joshua will clarify before any session or print decision.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          {processSteps.map((step, index) => (
            <article class="surface p-5">
              <span class="tag-pill">Step {index + 1}</span>
              <p class="mt-4 text-sm text-steel">{step}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
