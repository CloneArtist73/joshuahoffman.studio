---
import CTAButton from '../components/CTAButton.astro';
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getImageBySlug } from '../data/images';
import { products } from '../data/products';
import { contactClick } from '../utils/analytics';

const printProducts = products
  .map((product) => ({
    product,
    image: getImageBySlug(product.imageSlug),
  }))
  .filter((entry): entry is { product: (typeof products)[number]; image: NonNullable<ReturnType<typeof getImageBySlug>> } => Boolean(entry.image));
---

<Layout
  description="Selected photographs are available as prints through trusted external platforms. For custom sizing, signed work, or special requests, send a direct inquiry."
  path="/prints/"
  title="Fine-Art Prints"
>
  <section class="section-block">
    <div class="shell grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
      <div class="space-y-4">
        <span class="eyebrow">Fine-art prints</span>
        <h1 class="headline max-w-4xl">Selected photographs available as prints, with outbound checkout kept simple.</h1>
        <p class="max-w-copy text-base text-steel sm:text-lg">
          Selected photographs are available as prints through trusted external platforms. For custom sizing, signed work, or special requests, send a direct inquiry.
        </p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row lg:justify-end">
        <CTAButton href="/gallery/" label="Explore Gallery" variant="secondary" />
        <CTAButton
          href="/contact/?type=Print%20or%20product%20question"
          label="Ask About Custom Print"
          tracking={contactClick({ location: 'prints_intro', intent: 'custom_print' })}
        />
      </div>
    </div>
  </section>

  <section class="section-block pt-0">
    <div class="shell grid gap-6 lg:grid-cols-2">
      {printProducts.map(({ product, image }) => <ProductCard image={image} product={product} />)}
    </div>
  </section>
</Layout>
