---
import ContactForm from '../components/ContactForm.astro';
import CTAButton from '../components/CTAButton.astro';
import Layout from '../components/Layout.astro';
import { siteConfig } from '../data/site';
import { contactClick } from '../utils/analytics';

const inquiryGuidance = [
  'What kind of photographs, print, or license you need',
  'Timing, location, and where the images need to work',
  'Any privacy, family, memorial, or usage details Joshua should understand early',
];
---

<Layout
  description="Simple contact page for portrait sessions, legacy work, musician portraits, print questions, and licensing inquiries."
  path="/contact/"
  title="Contact"
>
  <section class="section-block">
    <div class="shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="space-y-5">
        <span class="eyebrow">Contact</span>
        <h1 class="headline max-w-3xl">Start with a short message.</h1>
        <p class="max-w-copy text-base text-steel sm:text-lg">
          Reach out about portrait sessions, legacy work, musician portraits, print questions, licensing, or anything else that fits the site.
        </p>
        <div class="surface space-y-5 p-6">
          <p class="text-sm text-steel">
            Direct email: <a
              class="panel-link text-paper underline decoration-white/20 underline-offset-4 hover:decoration-platinum"
              href={`mailto:${siteConfig.email}`}
              data-link-type="email_contact"
              data-link-label={`Email contact: ${siteConfig.email}`}
              data-link-location="contact_page_intro"
              {...contactClick({ location: 'contact_page_intro_email' })}
            >
              {siteConfig.email}
            </a>
          </p>
          <p class="text-sm text-steel">Service area: {siteConfig.serviceArea}</p>
          <div class="border-t border-white/10 pt-5">
            <h2 class="text-xl">What to include</h2>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-steel">
              {inquiryGuidance.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <CTAButton
            href="/about/"
            label="About Joshua"
            trackingMeta={{
              'data-link-type': 'internal_navigation',
              'data-link-location': 'contact_page_sidebar',
            }}
            variant="ghost"
          />
        </div>
      </div>

      <div class="space-y-5">
        <ContactForm />
        <noscript>
          <p class="text-sm text-steel">
            JavaScript is disabled in this browser. You can still reach Joshua directly at
            <a
              class="panel-link ml-2 underline underline-offset-4"
              href={`mailto:${siteConfig.email}`}
              data-link-type="email_contact"
              data-link-label={`Email contact: ${siteConfig.email}`}
              data-link-location="contact_form_noscript"
              {...contactClick({ location: 'contact_page_noscript_email' })}
            >
              {siteConfig.email}
            </a>
            .
          </p>
        </noscript>
        <p class="text-sm text-steel">
          Joshua replies directly. For the clearest reply, include timing, location, and the kind of photographs or print question you have in mind.
        </p>
      </div>
    </div>
  </section>
</Layout>
