---
import ContactForm from '../components/ContactForm.astro';
import CTAButton from '../components/CTAButton.astro';
import Layout from '../components/Layout.astro';
import { siteConfig } from '../data/site';
import { contactClick } from '../utils/analytics';

const inquiryGuidance = [
  'Which print, photograph, session, or license you are asking about',
  'Timing, location, storefront issue, or where the image needs to work',
  'For restoration work, what you have now and what you want improved or printed',
];
---

<Layout
  description="Contact Joshua Hoffman Studio about physical prints, astrophotography, portraits, restoration-style work, musician portraits, and licensing inquiries."
  path="/contact/"
  title="Contact"
>
  <section class="section-block">
    <div class="shell space-y-8">
      <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
        <div class="space-y-5">
        <span class="eyebrow">Contact</span>
        <h1 class="headline max-w-3xl">Start with a short message.</h1>
        <p class="max-w-copy text-base leading-relaxed text-steel sm:text-lg">
          Reach out about physical prints, astrophotography, portrait sessions, musician portraits, restoration-style print work, or licensing.
        </p>
        <div class="flex flex-col gap-3 sm:flex-row">
          <CTAButton href="#inquiry-form" label="Go to Form" variant="secondary" />
          <CTAButton
            href={`mailto:${siteConfig.email}`}
            label="Email Directly"
            tracking={contactClick({ location: 'contact_intro_email_cta' })}
            trackingMeta={{
              'data-link-type': 'email_contact',
              'data-link-location': 'contact_intro_email_cta',
            }}
            variant="ghost"
          />
        </div>
        </div>
        <p class="editorial-statement max-w-2xl lg:justify-self-end">
          A clear first note is enough. Product, location, timing, and usage details can be narrowed before anything is scheduled, licensed, or ordered.
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="surface order-2 space-y-5 p-6 lg:order-1">
          <p class="text-sm text-steel">
            Direct email: <a
              class="panel-link text-paper underline decoration-white/20 underline-offset-4 hover:decoration-platinum"
              href={`mailto:${siteConfig.email}`}
              data-link-type="email_contact"
              data-link-label={`Email contact: ${siteConfig.email}`}
              data-link-location="contact_page_intro"
              {...contactClick({ location: 'contact_page_intro_email' })}
            >
              {siteConfig.email}
            </a>
          </p>
          <p class="text-sm text-steel">Service area: {siteConfig.serviceArea}</p>
          <div class="border-t border-white/10 pt-5">
            <h2 class="text-xl">What to include</h2>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-steel">
              {inquiryGuidance.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <CTAButton
            href="/about/"
            label="About Joshua"
            trackingMeta={{
              'data-link-type': 'internal_navigation',
              'data-link-location': 'contact_page_sidebar',
            }}
            variant="ghost"
          />
        </div>

      <div class="order-1 space-y-5 lg:order-2" id="inquiry-form">
        <ContactForm />
        <noscript>
          <p class="text-sm text-steel">
            JavaScript is disabled in this browser. You can still reach Joshua directly at
            <a
              class="panel-link ml-2 underline underline-offset-4"
              href={`mailto:${siteConfig.email}`}
              data-link-type="email_contact"
              data-link-label={`Email contact: ${siteConfig.email}`}
              data-link-location="contact_form_noscript"
              {...contactClick({ location: 'contact_page_noscript_email' })}
            >
              {siteConfig.email}
            </a>
            .
          </p>
        </noscript>
        <p class="text-sm text-steel">
          Joshua replies directly. For the clearest reply, include the image or print you are asking about, timing, location, and any usage details.
        </p>
      </div>
      </div>
    </div>
  </section>
</Layout>
