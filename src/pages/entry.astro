---
import ContentEntryForm from '../components/ContentEntryForm.astro';
import Layout from '../components/Layout.astro';
import { images } from '../data/images';
import { products } from '../data/products';
import { externalLinks } from '../data/externalLinks';

const entryEnabled = import.meta.env.DEV || import.meta.env.PUBLIC_ENABLE_ENTRY === 'true';
const entryFormSeedData = {
  images,
  products,
  externalLinks,
};
const entryFormSeedJson = JSON.stringify(entryFormSeedData).replace(/</g, '\\u003c');
---

<Layout
  description="Local helper page for adding image, product, and outbound URL data to static Astro data files."
  noindex
  path="/entry/"
  title="Content Entry Helper"
>
  {
    entryEnabled ? (
      <ContentEntryForm seedData={entryFormSeedJson} />
    ) : (
      <section class="mx-auto flex min-h-[60vh] max-w-2xl flex-col justify-center px-6 py-24">
        <p class="eyebrow">Local tool disabled</p>
        <h1 class="mt-4 text-3xl font-semibold text-paper">Content entry is not available on the public site.</h1>
        <p class="mt-4 max-w-copy text-base leading-7 text-steel">
          Run the site locally in development mode to add gallery entries. This keeps the public build static and
          visitor-facing.
        </p>
      </section>
    )
  }
</Layout>
